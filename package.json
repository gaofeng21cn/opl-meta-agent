{
  "name": "opl-meta-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build-agent-baseline": "node --experimental-strip-types scripts/build-agent-baseline.ts",
    "improve:external-suite": "node --experimental-strip-types scripts/improve-from-agent-lab-suite.ts",
    "execute:external-work-order": "node --experimental-strip-types scripts/execute-external-work-order.ts",
    "agent:evidence": "node --experimental-strip-types scripts/lib/agent-evidence-materializer.ts",
    "takeover:test": "node --experimental-strip-types scripts/takeover-agent.ts",
    "repo:hygiene": "scripts/repo-hygiene.sh",
    "repo:hygiene:fix": "scripts/repo-hygiene.sh --fix",
    "authority-functions:check": "scripts/run-with-repo-temp-env.sh node scripts/sync-authority-functions.ts --check",
    "authority-functions:write": "scripts/run-with-repo-temp-env.sh node scripts/sync-authority-functions.ts --write",
    "authority-functions:split": "scripts/run-with-repo-temp-env.sh node scripts/sync-authority-functions.ts --split",
    "stage-control:check": "scripts/run-with-repo-temp-env.sh node scripts/sync-stage-control-plane.ts --check",
    "stage-control:write": "scripts/run-with-repo-temp-env.sh node scripts/sync-stage-control-plane.ts --write",
    "stage-control:split": "scripts/run-with-repo-temp-env.sh node scripts/sync-stage-control-plane.ts --split",
    "source-structure": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --advisory",
    "source-structure:json": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --advisory --json",
    "source-structure:strict": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --strict",
    "source-structure:strict:json": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --strict --json",
    "script-to-pack:readback": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --strict --script-to-pack-readback",
    "script-to-pack:readback:full": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --strict --script-to-pack-readback-full",
    "line-budget": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --advisory",
    "line-budget:strict": "scripts/run-with-repo-temp-env.sh node scripts/check-source-structure.ts --strict",
    "verify": "scripts/verify.sh",
    "typecheck": "scripts/run-with-repo-temp-env.sh tsc --noEmit",
    "test": "npm run test:smoke",
    "test:smoke": "scripts/run-with-repo-temp-env.sh node --test tests/contracts-repo-hygiene.test.ts tests/contracts-action-authority.test.ts tests/contracts-domain-pack.test.ts tests/contracts-generated-surfaces.test.ts tests/contracts-foundry-series.test.ts tests/source-purity.test.ts tests/source-purity-boundary.test.ts",
    "test:behavior": "scripts/run-with-repo-temp-env.sh node --test tests/bootstrap-loop.test.ts tests/stage-decomposition-materializer.test.ts tests/takeover-loop.test.ts tests/agent-evidence-materializer.test.ts tests/execute-external-work-order.test.ts tests/external-suite-*.test.ts tests/target-*.test.ts tests/live-stage-run-progress-evidence.test.ts tests/new-agent-consumption-evidence.test.ts",
    "test:full": "scripts/run-with-repo-temp-env.sh node --test tests/*.test.ts"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "opl-framework-shared": "git+https://github.com/gaofeng21cn/one-person-lab.git#05fc5aa4425acca0a5c6f3f02eafbc82ec902af4"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3"
  }
}
