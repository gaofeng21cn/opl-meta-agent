{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/materialize-trajectory-learning-proposal.input.schema.json",
  "title": "Materialize Trajectory Learning Proposal Input",
  "description": "Refs-only trajectory evidence accepted by the OMA trajectory learning proposal action.",
  "type": "object",
  "required": [
    "redacted_trajectory_ref",
    "trajectory_atom_refs",
    "candidate_buffer_ref",
    "independent_ai_review_ref",
    "agent_lab_promotion_gate_ref"
  ],
  "properties": {
    "redacted_trajectory_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "trajectory_atom_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "candidate_buffer_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "independent_ai_review_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "agent_lab_promotion_gate_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "redaction_proof_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "source_owner_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "team_sync_policy_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "ux_canary_signal_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  },
  "additionalProperties": false
}
