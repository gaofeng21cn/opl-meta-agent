{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/standard-agent-developer-proof-receipt.consumer.schema.json",
  "title": "OMA Standard Agent Developer Proof Receipt Consumer",
  "description": "The only aggregate Framework receipt accepted by the OMA developer helper for profile, scaffold, generated-interface, package-manifest, and profile-conformance proof results.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "request_id",
    "request_ref",
    "request_sha256",
    "target_identity",
    "status",
    "proofs",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_standard_agent_developer_proof_receipt" },
    "version": { "const": "opl-standard-agent-developer-proof-receipt.v1" },
    "request_id": { "$ref": "#/$defs/nonEmptyString" },
    "request_ref": { "$ref": "#/$defs/nonEmptyString" },
    "request_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "target_identity": { "$ref": "#/$defs/targetIdentity" },
    "status": { "enum": ["passed", "blocked"] },
    "proofs": {
      "type": "object",
      "required": [
        "profile_inspect_select",
        "scaffold_materialize_validate",
        "generated_interfaces",
        "package_manifest_validate",
        "profile_conformance"
      ],
      "properties": {
        "profile_inspect_select": {
          "$ref": "#/$defs/profileInspectSelectProof"
        },
        "scaffold_materialize_validate": {
          "$ref": "#/$defs/scaffoldMaterializeValidateProof"
        },
        "generated_interfaces": {
          "$ref": "#/$defs/generatedInterfacesProof"
        },
        "package_manifest_validate": {
          "$ref": "#/$defs/packageManifestValidateProof"
        },
        "profile_conformance": {
          "$ref": "#/$defs/profileConformanceProof"
        }
      },
      "additionalProperties": false
    },
    "blockers": { "$ref": "#/$defs/stringArray" },
    "authority_boundary": {
      "type": "object",
      "required": [
        "execution_owner",
        "receipt_owner",
        "oma_consumes_receipt_only",
        "receipt_can_write_target_domain_truth",
        "receipt_can_authorize_target_quality_or_export"
      ],
      "properties": {
        "execution_owner": { "const": "one-person-lab/OPL Framework" },
        "receipt_owner": { "const": "one-person-lab/OPL Framework" },
        "oma_consumes_receipt_only": { "const": true },
        "receipt_can_write_target_domain_truth": { "const": false },
        "receipt_can_authorize_target_quality_or_export": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "targetIdentity": {
      "type": "object",
      "required": ["domain_id", "target_agent_ref"],
      "properties": {
        "domain_id": { "$ref": "#/$defs/nonEmptyString" },
        "target_agent_ref": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "proof": {
      "type": "object",
      "required": ["operation_id", "status", "input_refs", "output"],
      "properties": {
        "operation_id": {
          "enum": [
            "profile_inspect_select",
            "scaffold_materialize_validate",
            "generated_interfaces",
            "package_manifest_validate",
            "profile_conformance"
          ]
        },
        "status": { "enum": ["passed", "blocked"] },
        "input_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "uniqueItems": true
        },
        "output": { "type": "object" },
        "blockers": { "$ref": "#/$defs/stringArray" }
      },
      "additionalProperties": false
    },
    "profileInspectSelectProof": {
      "allOf": [
        { "$ref": "#/$defs/proof" },
        {
          "properties": {
            "operation_id": { "const": "profile_inspect_select" },
            "output": {
              "type": "object",
              "required": ["profile_selection_receipt", "profile_inspection_readbacks"],
              "properties": {
                "profile_selection_receipt": {
                  "type": "object",
                  "required": ["surface_kind", "selected_profile_refs"],
                  "properties": {
                    "surface_kind": { "const": "opl_profile_selection_receipt" },
                    "selected_profile_refs": { "$ref": "#/$defs/stringArray" },
                    "matched_trigger_signals": { "$ref": "#/$defs/stringArray" }
                  },
                  "additionalProperties": true
                },
                "profile_inspection_readbacks": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "scaffoldMaterializeValidateProof": {
      "allOf": [
        { "$ref": "#/$defs/proof" },
        {
          "properties": {
            "operation_id": { "const": "scaffold_materialize_validate" },
            "output": {
              "type": "object",
              "required": [
                "scaffold_materialization_receipt",
                "standard_domain_agent_scaffold"
              ],
              "properties": {
                "scaffold_materialization_receipt": {
                  "type": "object",
                  "required": [
                    "surface_kind",
                    "status",
                    "build_receipt_ref",
                    "build_receipt",
                    "materialized_file_digests",
                    "validation_refs"
                  ],
                  "properties": {
                    "surface_kind": { "const": "opl_agent_scaffold_materialization_receipt" },
                    "status": { "const": "materialized" },
                    "build_receipt_ref": { "$ref": "#/$defs/nonEmptyString" },
                    "build_receipt": { "type": "object" },
                    "materialized_file_digests": {
                      "type": "array",
                      "minItems": 1,
                      "items": { "type": "object" }
                    },
                    "validation_refs": {
                      "type": "array",
                      "minItems": 1,
                      "items": { "$ref": "#/$defs/nonEmptyString" }
                    }
                  },
                  "additionalProperties": true
                },
                "standard_domain_agent_scaffold": {
                  "type": "object",
                  "required": ["validation"],
                  "properties": {
                    "validation": {
                      "type": "object",
                      "required": ["status"],
                      "properties": {
                        "status": { "const": "passed" },
                        "blockers": { "$ref": "#/$defs/stringArray" }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "generatedInterfacesProof": {
      "allOf": [
        { "$ref": "#/$defs/proof" },
        {
          "properties": {
            "operation_id": { "const": "generated_interfaces" },
            "output": {
              "type": "object",
              "required": ["generated_agent_interfaces"],
              "properties": {
                "generated_agent_interfaces": {
                  "type": "object",
                  "required": ["status"],
                  "properties": { "status": { "const": "ready" } },
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "packageManifestValidateProof": {
      "allOf": [
        { "$ref": "#/$defs/proof" },
        {
          "properties": {
            "operation_id": { "const": "package_manifest_validate" },
            "output": {
              "type": "object",
              "required": ["opl_agent_package_manifest"],
              "properties": {
                "opl_agent_package_manifest": {
                  "type": "object",
                  "required": ["status"],
                  "properties": { "status": { "const": "valid" } },
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "profileConformanceProof": {
      "allOf": [
        { "$ref": "#/$defs/proof" },
        {
          "properties": {
            "operation_id": { "const": "profile_conformance" },
            "output": {
              "type": "object",
              "required": ["profile_conformance"],
              "properties": {
                "profile_conformance": {
                  "type": "object",
                  "required": ["status"],
                  "properties": {
                    "status": { "enum": ["passed", "not_applicable"] }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
