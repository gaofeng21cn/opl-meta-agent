{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/takeover-target-agent-test.output.schema.json",
  "title": "Take Over Target Agent Test Output",
  "description": "A thin declarative takeover evaluation request and canonical OPL Foundry Lab work order. OPL compiles the suite plan; OMA creates no suite result or owner receipt.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "status",
    "product_id",
    "takeover_policy",
    "target_agent",
    "artifacts",
    "agent_building_judgment",
    "foundry_lab_handoff",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_meta_agent_takeover_handoff"
    },
    "version": {
      "const": "opl-meta-agent.takeover-handoff.v1"
    },
    "status": {
      "const": "takeover_candidate_materialized_ready_for_opl_foundry_lab_evaluation"
    },
    "product_id": {
      "const": "opl-meta-agent"
    },
    "domain_pack_status": { "type": "string" },
    "prompt_policy_refs": { "$ref": "#/$defs/stringArray" },
    "skill_policy_refs": { "$ref": "#/$defs/stringArray" },
    "quality_gate_refs": { "$ref": "#/$defs/stringArray" },
    "knowledge_policy_refs": { "$ref": "#/$defs/stringArray" },
    "source_domain_pack": { "type": "object" },
    "takeover_policy": {
      "type": "object",
      "required": [
        "target_opl_compatible_agents_allowed",
        "can_execute_agent_lab_suite",
        "can_write_target_owner_receipt_body",
        "can_write_target_domain_truth",
        "can_promote_default_agent_without_gate"
      ],
      "properties": {
        "target_opl_compatible_agents_allowed": {
          "const": true
        },
        "can_execute_agent_lab_suite": {
          "const": false
        },
        "can_write_target_owner_receipt_body": {
          "const": false
        },
        "can_write_target_domain_truth": {
          "const": false
        },
        "can_write_target_quality_verdict": { "const": false },
        "can_write_target_artifact_body": { "const": false },
        "can_write_target_memory_body": { "const": false },
        "can_promote_default_agent_without_gate": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "target_agent": {
      "$ref": "#/$defs/targetIdentity"
    },
    "artifacts": {
      "type": "object",
      "required": [
        "foundry_evaluation_request_path",
        "foundry_lab_work_order_path"
      ],
      "properties": {
        "foundry_evaluation_request_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "foundry_lab_work_order_path": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "agent_building_judgment": {
      "type": "object",
      "required": [
        "ai_reviewer_evaluation_ref",
        "verdict",
        "suggestions",
        "candidate_refs"
      ],
      "properties": {
        "ai_reviewer_evaluation_ref": { "$ref": "#/$defs/nonEmptyString" },
        "verdict": { "$ref": "#/$defs/nonEmptyString" },
        "suggestions": { "$ref": "#/$defs/nonEmptyStringArray" },
        "candidate_refs": { "$ref": "#/$defs/stringArray" }
      },
      "additionalProperties": false
    },
    "foundry_lab_handoff": {
      "$ref": "#/$defs/foundryHandoff"
    },
    "authority_boundary": {
      "$ref": "#/$defs/authorityBoundary"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "targetIdentity": {
      "type": "object",
      "required": [
        "domain_id",
        "repo_dir",
        "target_agent_ref",
        "descriptor_ref"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repo_dir": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "descriptor_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_label": { "type": ["string", "null"] },
        "delivery_domain": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "foundryHandoff": {
      "type": "object",
      "required": [
        "evaluation_request",
        "work_order"
      ],
      "properties": {
        "evaluation_request": {
          "type": "object",
          "required": [
            "surface_kind",
            "version",
            "request_id",
            "suite_id",
            "suite_kind",
            "task_intents",
            "authority_boundary"
          ],
          "properties": {
            "surface_kind": {
              "const": "opl_meta_agent_foundry_evaluation_request"
            },
            "version": {
              "const": "opl-meta-agent.foundry-evaluation-request.v1"
            },
            "request_id": { "$ref": "#/$defs/nonEmptyString" },
            "suite_id": { "$ref": "#/$defs/nonEmptyString" },
            "suite_kind": { "const": "agent_lab_external_suite" },
            "task_intents": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "task_id",
                  "domain_id",
                  "task_family",
                  "instructions_ref",
                  "agent_entry_ref",
                  "stage_refs",
                  "oracle_refs",
                  "scorer_refs",
                  "metric_refs",
                  "evidence_refs",
                  "review_refs",
                  "quality_gate_refs",
                  "trajectory_ref",
                  "requested_run_ref",
                  "artifact_refs",
                  "receipt_refs",
                  "scorecard_ref",
                  "improvement_candidate",
                  "promotion_gate_ref"
                ],
                "properties": {
                  "task_id": { "$ref": "#/$defs/nonEmptyString" },
                  "domain_id": { "const": "opl-meta-agent" },
                  "task_family": { "$ref": "#/$defs/nonEmptyString" },
                  "instructions_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "agent_entry_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "stage_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "oracle_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "scorer_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "metric_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "evidence_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "review_refs": { "$ref": "#/$defs/stringArray" },
                  "quality_gate_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "trajectory_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "requested_run_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "artifact_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "receipt_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
                  "scorecard_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "improvement_candidate": {
                    "type": "object",
                    "required": ["candidate_ref", "candidate_kind", "target_ref", "allowed_change_scope"],
                    "properties": {
                      "candidate_ref": { "$ref": "#/$defs/nonEmptyString" },
                      "candidate_kind": { "$ref": "#/$defs/nonEmptyString" },
                      "target_ref": { "$ref": "#/$defs/nonEmptyString" },
                      "allowed_change_scope": { "const": "branch_only" }
                    },
                    "additionalProperties": false
                  },
                  "promotion_gate_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "promotion_gate_required_refs": { "$ref": "#/$defs/stringArray" },
                  "regression_suite_refs": { "$ref": "#/$defs/stringArray" }
                },
                "additionalProperties": false
              }
            },
            "authority_boundary": {
              "type": "object",
              "required": [
                "refs_only",
                "oma_can_execute_agent_lab_suite",
                "oma_can_write_agent_lab_result",
                "oma_can_write_owner_receipt_body",
                "oma_can_write_promotion_gate",
                "oma_can_claim_target_domain_ready",
                "oma_can_claim_target_production_ready"
              ],
              "properties": {
                "refs_only": { "const": true },
                "oma_can_execute_agent_lab_suite": { "const": false },
                "oma_can_write_agent_lab_result": { "const": false },
                "oma_can_write_owner_receipt_body": { "const": false },
                "oma_can_write_promotion_gate": { "const": false },
                "oma_can_claim_target_domain_ready": { "const": false },
                "oma_can_claim_target_production_ready": { "const": false }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "work_order": {
          "type": "object",
          "required": [
            "surface_kind",
            "version",
            "work_order_id",
            "work_order_kind",
            "status",
            "product_id",
            "execution_owner",
            "target_agent",
            "evaluation_request",
            "source_refs",
            "reviewer_refs",
            "candidate_refs",
            "requested_operations",
            "expected_return_shapes",
            "consumer_dependency",
            "execution_aperture",
            "authority_boundary"
          ],
          "properties": {
            "surface_kind": {
              "const": "opl_meta_agent_foundry_lab_work_order_candidate"
            },
            "version": { "const": "opl-meta-agent.foundry-lab-work-order-candidate.v1" },
            "work_order_id": { "$ref": "#/$defs/nonEmptyString" },
            "work_order_kind": { "const": "target_agent_takeover_evaluation" },
            "status": {
              "const": "ready_for_opl_foundry_lab_evaluation"
            },
            "product_id": { "const": "opl-meta-agent" },
            "execution_owner": { "const": "one-person-lab/OPL Foundry Lab" },
            "target_agent": { "$ref": "#/$defs/targetIdentity" },
            "evaluation_request": {
              "type": "object",
              "required": ["ref", "sha256", "request_id", "suite_id", "suite_kind"],
              "properties": {
                "ref": { "$ref": "#/$defs/nonEmptyString" },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "request_id": { "$ref": "#/$defs/nonEmptyString" },
                "suite_id": { "$ref": "#/$defs/nonEmptyString" },
                "suite_kind": { "const": "agent_lab_external_suite" }
              },
              "additionalProperties": false
            },
            "source_refs": { "$ref": "#/$defs/stringArray" },
            "reviewer_refs": { "$ref": "#/$defs/stringArray" },
            "candidate_refs": { "$ref": "#/$defs/stringArray" },
            "requested_operations": { "$ref": "#/$defs/stringArray" },
            "expected_return_shapes": { "$ref": "#/$defs/stringArray" },
            "consumer_dependency": { "$ref": "#/$defs/consumerDependency" },
            "execution_aperture": { "$ref": "#/$defs/executionAperture" },
            "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "oma_can_execute_agent_lab_suite",
        "oma_can_write_agent_lab_result",
        "oma_can_write_owner_receipt_body",
        "oma_can_write_learning_candidate_ledger",
        "oma_can_write_promotion_gate",
        "oma_can_write_mechanism_or_scaleout_ledger",
        "oma_can_manage_work_order_lifecycle",
        "oma_can_write_target_domain_truth",
        "oma_can_write_target_domain_memory_body",
        "oma_can_mutate_target_domain_artifact_body",
        "oma_can_authorize_target_domain_quality_or_export",
        "oma_can_claim_target_domain_ready",
        "oma_can_claim_target_production_ready",
        "oma_can_promote_default_agent_without_gate"
      ],
      "properties": {
        "oma_can_execute_agent_lab_suite": {
          "const": false
        },
        "oma_can_write_agent_lab_result": {
          "const": false
        },
        "oma_can_write_owner_receipt_body": {
          "const": false
        },
        "oma_can_write_learning_candidate_ledger": { "const": false },
        "oma_can_write_promotion_gate": { "const": false },
        "oma_can_write_mechanism_or_scaleout_ledger": { "const": false },
        "oma_can_manage_work_order_lifecycle": { "const": false },
        "oma_can_write_target_domain_truth": {
          "const": false
        },
        "oma_can_write_target_domain_memory_body": { "const": false },
        "oma_can_mutate_target_domain_artifact_body": { "const": false },
        "oma_can_authorize_target_domain_quality_or_export": { "const": false },
        "oma_can_claim_target_domain_ready": { "const": false },
        "oma_can_claim_target_production_ready": { "const": false },
        "oma_can_promote_default_agent_without_gate": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "consumerDependency": {
      "type": "object",
      "required": ["status", "owner", "required_consumer_role"],
      "properties": {
        "status": { "const": "available" },
        "owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "required_consumer_role": { "const": "compile_evaluation_work_order_to_agent_lab_suite_and_execute" }
      },
      "additionalProperties": false
    },
    "executionAperture": {
      "type": "object",
      "required": ["action_ref", "work_order_lifecycle_owner", "result_ledger_owner", "target_owner_closeout_owner"],
      "properties": {
        "action_ref": { "const": "opl agent-lab evaluation-work-order execute --work-order <work-order.json> --output <dir>" },
        "work_order_lifecycle_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "result_ledger_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_owner_closeout_owner": { "const": "target-domain" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
