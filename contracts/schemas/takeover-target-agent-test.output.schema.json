{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/takeover-target-agent-test.output.schema.json",
  "title": "Take Over Target Agent Test Output",
  "description": "A declarative takeover suite seed and canonical OPL Foundry Lab evaluation work order. No suite result or owner receipt is created by OMA.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "status",
    "product_id",
    "takeover_policy",
    "target_agent",
    "artifacts",
    "agent_building_judgment",
    "foundry_lab_handoff",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_meta_agent_takeover_handoff"
    },
    "version": {
      "const": "opl-meta-agent.takeover-handoff.v1"
    },
    "status": {
      "const": "takeover_candidate_materialized_ready_for_opl_foundry_lab_evaluation"
    },
    "product_id": {
      "const": "opl-meta-agent"
    },
    "takeover_policy": {
      "type": "object",
      "required": [
        "target_opl_compatible_agents_allowed",
        "can_execute_agent_lab_suite",
        "can_write_target_owner_receipt_body",
        "can_write_target_domain_truth",
        "can_promote_default_agent_without_gate"
      ],
      "properties": {
        "target_opl_compatible_agents_allowed": {
          "const": true
        },
        "can_execute_agent_lab_suite": {
          "const": false
        },
        "can_write_target_owner_receipt_body": {
          "const": false
        },
        "can_write_target_domain_truth": {
          "const": false
        },
        "can_promote_default_agent_without_gate": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "target_agent": {
      "$ref": "#/$defs/targetIdentity"
    },
    "artifacts": {
      "type": "object",
      "required": [
        "agent_lab_suite_seed_path",
        "foundry_lab_work_order_path"
      ],
      "properties": {
        "agent_lab_suite_seed_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "foundry_lab_work_order_path": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "agent_building_judgment": {
      "type": "object",
      "required": [
        "ai_reviewer_evaluation_ref",
        "verdict",
        "suggestions",
        "candidate_refs"
      ],
      "additionalProperties": true
    },
    "foundry_lab_handoff": {
      "$ref": "#/$defs/foundryHandoff"
    },
    "authority_boundary": {
      "$ref": "#/$defs/authorityBoundary"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "targetIdentity": {
      "type": "object",
      "required": [
        "domain_id",
        "repo_dir",
        "target_agent_ref",
        "descriptor_ref"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repo_dir": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "descriptor_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "foundryHandoff": {
      "type": "object",
      "required": [
        "suite_seed",
        "work_order"
      ],
      "properties": {
        "suite_seed": {
          "type": "object",
          "required": [
            "surface_kind",
            "target_agent_ref",
            "target_agent_descriptor_ref",
            "tasks"
          ],
          "properties": {
            "surface_kind": {
              "const": "opl_meta_agent_agent_lab_suite_seed"
            }
          },
          "additionalProperties": true
        },
        "work_order": {
          "type": "object",
          "required": [
            "surface_kind",
            "status",
            "target_agent",
            "consumer_dependency",
            "execution_aperture"
          ],
          "properties": {
            "surface_kind": {
              "const": "opl_meta_agent_foundry_lab_work_order_candidate"
            },
            "status": {
              "const": "ready_for_opl_foundry_lab_evaluation"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "oma_can_execute_agent_lab_suite",
        "oma_can_write_agent_lab_result",
        "oma_can_write_owner_receipt_body",
        "oma_can_write_target_domain_truth",
        "oma_can_promote_default_agent_without_gate"
      ],
      "properties": {
        "oma_can_execute_agent_lab_suite": {
          "const": false
        },
        "oma_can_write_agent_lab_result": {
          "const": false
        },
        "oma_can_write_owner_receipt_body": {
          "const": false
        },
        "oma_can_write_target_domain_truth": {
          "const": false
        },
        "oma_can_promote_default_agent_without_gate": {
          "const": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
