{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/takeover-target-agent-test.output.schema.json",
  "title": "Take Over Target Agent Test Output",
  "description": "OMA takeover judgment with an OMA-owned agent-building semantic request. OPL owns request materialization, work-order identity, execution, receipts, worktree lifecycle, and target-owner closeout.",
  "type": "object",
  "required": [
    "surface_kind", "version", "status", "product_id", "takeover_policy", "target_agent",
    "agent_building_judgment", "foundry_lab_handoff", "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_meta_agent_takeover_handoff" },
    "version": { "const": "opl-meta-agent.takeover-handoff.v1" },
    "status": {
      "enum": [
        "takeover_candidate_materialized_ready_for_opl_foundry_lab_evaluation",
        "completed_with_quality_debt"
      ]
    },
    "product_id": { "const": "opl-meta-agent" },
    "domain_pack_status": { "type": "string" },
    "prompt_policy_refs": { "$ref": "#/$defs/stringArray" },
    "skill_policy_refs": { "$ref": "#/$defs/stringArray" },
    "quality_gate_refs": { "$ref": "#/$defs/stringArray" },
    "knowledge_policy_refs": { "$ref": "#/$defs/stringArray" },
    "source_domain_pack": { "type": "object" },
    "takeover_policy": {
      "type": "object",
      "required": [
        "target_opl_compatible_agents_allowed", "can_execute_agent_lab_suite",
        "can_write_target_domain_truth", "can_write_target_quality_verdict",
        "can_write_target_artifact_body", "can_write_target_memory_body",
        "can_write_target_owner_receipt_body", "can_promote_default_agent_without_gate"
      ],
      "properties": {
        "target_opl_compatible_agents_allowed": { "const": true },
        "can_execute_agent_lab_suite": { "const": false },
        "can_write_target_domain_truth": { "const": false },
        "can_write_target_quality_verdict": { "const": false },
        "can_write_target_artifact_body": { "const": false },
        "can_write_target_memory_body": { "const": false },
        "can_write_target_owner_receipt_body": { "const": false },
        "can_promote_default_agent_without_gate": { "const": false }
      },
      "additionalProperties": false
    },
    "target_agent": { "$ref": "#/$defs/outputTargetAgent" },
    "agent_building_judgment": {
      "type": "object",
      "required": ["ai_reviewer_evaluation_ref", "verdict", "suggestions", "candidate_refs"],
      "properties": {
        "ai_reviewer_evaluation_ref": { "$ref": "#/$defs/nonEmptyString" },
        "verdict": { "$ref": "#/$defs/nonEmptyString" },
        "suggestions": { "$ref": "#/$defs/nonEmptyStringArray" },
        "candidate_refs": { "$ref": "#/$defs/nonEmptyStringArray" }
      },
      "additionalProperties": false
    },
    "foundry_lab_handoff": {
      "type": "object",
      "required": ["materialization_request"],
      "properties": {
        "materialization_request": { "$ref": "#/$defs/workOrderMaterializationRequest" }
      },
      "additionalProperties": false
    },
    "quality_debt": {
      "type": "object",
      "required": ["reasons", "blocks_stage_transition", "blocks_delivery_or_promotion_claims"],
      "properties": {
        "reasons": { "$ref": "#/$defs/nonEmptyStringArray" },
        "blocks_stage_transition": { "const": false },
        "blocks_delivery_or_promotion_claims": { "const": true }
      },
      "additionalProperties": false
    },
    "next_stage_may_start": { "const": true },
    "semantic_route_decision_owner": { "const": "decisive_codex_attempt" },
    "stage_transition_materialization_owner": { "const": "opl_stage_run_controller" },
    "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "completed_with_quality_debt" } } },
      "then": {
        "required": [
          "quality_debt", "next_stage_may_start", "semantic_route_decision_owner",
          "stage_transition_materialization_owner"
        ]
      }
    }
  ],
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "outputTargetAgent": {
      "type": "object",
      "required": ["domain_id", "repo_dir", "target_agent_ref", "descriptor_ref"],
      "properties": {
        "domain_id": { "$ref": "#/$defs/nonEmptyString" },
        "domain_label": { "type": ["string", "null"] },
        "delivery_domain": { "type": ["string", "null"] },
        "repo_dir": { "$ref": "#/$defs/nonEmptyString" },
        "target_agent_ref": { "$ref": "#/$defs/nonEmptyString" },
        "descriptor_ref": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "materializationTargetAgent": {
      "type": "object",
      "required": ["domain_id", "repo_dir", "target_agent_ref", "descriptor_ref"],
      "properties": {
        "domain_id": { "$ref": "#/$defs/nonEmptyString" },
        "repo_dir": { "$ref": "#/$defs/nonEmptyString" },
        "target_agent_ref": { "$ref": "#/$defs/nonEmptyString" },
        "descriptor_ref": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "improvementCandidate": {
      "type": "object",
      "required": ["candidate_ref", "candidate_kind", "target_ref", "allowed_change_scope"],
      "properties": {
        "candidate_ref": { "$ref": "#/$defs/nonEmptyString" },
        "candidate_kind": { "$ref": "#/$defs/nonEmptyString" },
        "target_ref": { "$ref": "#/$defs/nonEmptyString" },
        "allowed_change_scope": {
          "enum": ["candidate_config_only", "branch_only", "manual_review_required"]
        }
      },
      "additionalProperties": false
    },
    "evaluationTaskIntent": {
      "type": "object",
      "required": [
        "task_id", "domain_id", "task_family", "instructions_ref", "agent_entry_ref",
        "stage_refs", "oracle_refs", "scorer_refs", "metric_refs", "evidence_refs",
        "review_refs", "quality_gate_refs", "trajectory_ref", "requested_run_ref",
        "artifact_refs", "receipt_refs", "scorecard_ref", "improvement_candidate",
        "promotion_gate_ref"
      ],
      "properties": {
        "task_id": { "$ref": "#/$defs/nonEmptyString" },
        "domain_id": { "const": "opl-meta-agent" },
        "task_family": { "$ref": "#/$defs/nonEmptyString" },
        "instructions_ref": { "$ref": "#/$defs/nonEmptyString" },
        "agent_entry_ref": { "$ref": "#/$defs/nonEmptyString" },
        "stage_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "oracle_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "scorer_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "metric_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "evidence_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "review_refs": { "$ref": "#/$defs/stringArray" },
        "quality_gate_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "trajectory_ref": { "$ref": "#/$defs/nonEmptyString" },
        "requested_run_ref": { "$ref": "#/$defs/nonEmptyString" },
        "artifact_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "receipt_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "scorecard_ref": { "$ref": "#/$defs/nonEmptyString" },
        "improvement_candidate": { "$ref": "#/$defs/improvementCandidate" },
        "promotion_gate_ref": { "$ref": "#/$defs/nonEmptyString" },
        "promotion_gate_required_refs": { "$ref": "#/$defs/stringArray" },
        "regression_suite_refs": { "$ref": "#/$defs/stringArray" }
      },
      "additionalProperties": false
    },
    "foundryEvaluationSemanticRequest": {
      "type": "object",
      "required": [
        "request_id", "suite_id", "suite_kind", "task_intents", "source_refs",
        "reviewer_refs", "candidate_refs"
      ],
      "properties": {
        "request_id": { "$ref": "#/$defs/nonEmptyString" },
        "suite_id": { "$ref": "#/$defs/nonEmptyString" },
        "suite_kind": {
          "enum": ["agent_lab_external_suite", "agent_production_evidence_suite"]
        },
        "task_intents": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evaluationTaskIntent" }
        },
        "source_refs": { "$ref": "#/$defs/stringArray" },
        "reviewer_refs": { "$ref": "#/$defs/stringArray" },
        "candidate_refs": { "$ref": "#/$defs/stringArray" },
        "production_evidence_gate_ids": { "$ref": "#/$defs/nonEmptyStringArray" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "suite_kind": { "const": "agent_production_evidence_suite" } },
            "required": ["suite_kind"]
          },
          "then": { "required": ["production_evidence_gate_ids"] }
        }
      ],
      "additionalProperties": false
    },
    "workOrderMaterializationRequest": {
      "type": "object",
      "required": [
        "surface_kind", "version", "canonical_schema_ref", "request_kind", "request_owner",
        "producer_agent_id", "execution_owner", "target_agent", "semantic_request",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": { "const": "opl_work_order_materialization_request" },
        "version": { "const": "opl-work-order-materialization-request.v2" },
        "canonical_schema_ref": {
          "const": "contracts/opl-framework/work-order-materialization-request.schema.json"
        },
        "request_kind": { "const": "foundry_evaluation" },
        "request_owner": { "const": "oma" },
        "producer_agent_id": { "const": "oma" },
        "execution_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_agent": { "$ref": "#/$defs/materializationTargetAgent" },
        "semantic_request": { "$ref": "#/$defs/foundryEvaluationSemanticRequest" },
        "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
      },
      "additionalProperties": false
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "semantic_scope", "work_order_materialization_owner", "work_order_lifecycle_owner",
        "target_worktree_lifecycle_owner", "target_owner_closeout_owner",
        "producer_writes_framework_request_bundle", "producer_assigns_work_order_id",
        "producer_manages_executor_lease", "producer_manages_target_worktree",
        "producer_executes_work_order", "producer_writes_work_order_receipt",
        "producer_writes_target_owner_closeout"
      ],
      "properties": {
        "semantic_scope": { "const": "agent_building_request_only" },
        "work_order_materialization_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "work_order_lifecycle_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_worktree_lifecycle_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_owner_closeout_owner": { "const": "target-domain" },
        "producer_writes_framework_request_bundle": { "const": false },
        "producer_assigns_work_order_id": { "const": false },
        "producer_manages_executor_lease": { "const": false },
        "producer_manages_target_worktree": { "const": false },
        "producer_executes_work_order": { "const": false },
        "producer_writes_work_order_receipt": { "const": false },
        "producer_writes_target_owner_closeout": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
