{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/opl-work-order-materialization-request.v2.schema.json",
  "title": "OPL Work Order Materialization Request v2",
  "description": "OMA producer adoption schema for a domain-neutral OPL request carrying OMA-owned agent-building semantics. The canonical schema owner is OPL Framework; OPL owns work-order identity, materialization, lease, worktree, lifecycle, execution, receipt, and closeout mechanics.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "canonical_schema_ref",
    "request_kind",
    "request_owner",
    "producer_agent_id",
    "execution_owner",
    "target_agent",
    "semantic_request",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_work_order_materialization_request" },
    "version": { "const": "opl-work-order-materialization-request.v2" },
    "canonical_schema_ref": {
      "const": "contracts/opl-framework/work-order-materialization-request.schema.json"
    },
    "request_kind": {
      "enum": ["developer_patch", "foundry_evaluation"]
    },
    "request_owner": { "const": "oma" },
    "producer_agent_id": { "const": "oma" },
    "execution_owner": { "const": "one-person-lab/OPL Foundry Lab" },
    "target_agent": { "$ref": "#/$defs/targetAgent" },
    "semantic_request": { "type": "object" },
    "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
  },
  "oneOf": [
    {
      "required": ["request_kind"],
      "properties": {
        "request_kind": { "const": "foundry_evaluation" },
        "target_agent": {
          "allOf": [
            { "$ref": "#/$defs/targetAgent" },
            { "required": ["target_agent_ref", "descriptor_ref"] }
          ]
        },
        "semantic_request": { "$ref": "#/$defs/foundryEvaluationSemanticRequest" }
      }
    },
    {
      "required": ["request_kind"],
      "properties": {
        "request_kind": { "const": "developer_patch" },
        "semantic_request": { "$ref": "#/$defs/developerPatchSemanticRequest" }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "targetAgent": {
      "type": "object",
      "required": ["domain_id", "repo_dir"],
      "properties": {
        "domain_id": { "$ref": "#/$defs/nonEmptyString" },
        "repo_dir": { "$ref": "#/$defs/nonEmptyString" },
        "target_agent_ref": { "$ref": "#/$defs/nonEmptyString" },
        "descriptor_ref": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "foundryTaskIntent": {
      "type": "object",
      "required": [
        "task_id",
        "domain_id",
        "task_family",
        "instructions_ref",
        "agent_entry_ref",
        "stage_refs",
        "oracle_refs",
        "scorer_refs",
        "metric_refs",
        "evidence_refs",
        "review_refs",
        "quality_gate_refs",
        "trajectory_ref",
        "requested_run_ref",
        "artifact_refs",
        "receipt_refs",
        "scorecard_ref",
        "improvement_candidate",
        "promotion_gate_ref"
      ],
      "properties": {
        "task_id": { "$ref": "#/$defs/nonEmptyString" },
        "domain_id": { "const": "opl-meta-agent" },
        "task_family": { "$ref": "#/$defs/nonEmptyString" },
        "instructions_ref": { "$ref": "#/$defs/nonEmptyString" },
        "agent_entry_ref": { "$ref": "#/$defs/nonEmptyString" },
        "stage_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "oracle_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "scorer_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "metric_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "evidence_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "review_refs": { "$ref": "#/$defs/stringArray" },
        "quality_gate_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "trajectory_ref": { "$ref": "#/$defs/nonEmptyString" },
        "requested_run_ref": { "$ref": "#/$defs/nonEmptyString" },
        "artifact_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "receipt_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "scorecard_ref": { "$ref": "#/$defs/nonEmptyString" },
        "improvement_candidate": {
          "type": "object",
          "required": ["candidate_ref", "candidate_kind", "target_ref", "allowed_change_scope"],
          "properties": {
            "candidate_ref": { "$ref": "#/$defs/nonEmptyString" },
            "candidate_kind": { "$ref": "#/$defs/nonEmptyString" },
            "target_ref": { "$ref": "#/$defs/nonEmptyString" },
            "allowed_change_scope": {
              "enum": ["candidate_config_only", "branch_only", "manual_review_required"]
            }
          },
          "additionalProperties": false
        },
        "promotion_gate_ref": { "$ref": "#/$defs/nonEmptyString" },
        "promotion_gate_required_refs": { "$ref": "#/$defs/stringArray" },
        "regression_suite_refs": { "$ref": "#/$defs/stringArray" }
      },
      "additionalProperties": false
    },
    "foundryEvaluationSemanticRequest": {
      "type": "object",
      "required": [
        "request_id",
        "suite_id",
        "suite_kind",
        "task_intents",
        "source_refs",
        "reviewer_refs",
        "candidate_refs"
      ],
      "properties": {
        "request_id": { "$ref": "#/$defs/nonEmptyString" },
        "suite_id": { "$ref": "#/$defs/nonEmptyString" },
        "suite_kind": {
          "enum": ["agent_lab_external_suite", "agent_production_evidence_suite"]
        },
        "task_intents": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/foundryTaskIntent" }
        },
        "source_refs": { "$ref": "#/$defs/stringArray" },
        "reviewer_refs": { "$ref": "#/$defs/stringArray" },
        "candidate_refs": { "$ref": "#/$defs/stringArray" },
        "production_evidence_gate_ids": { "$ref": "#/$defs/nonEmptyStringArray" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "suite_kind": { "const": "agent_production_evidence_suite" }
            },
            "required": ["suite_kind"]
          },
          "then": {
            "required": ["production_evidence_gate_ids"]
          }
        }
      ],
      "additionalProperties": false
    },
    "developerPatchJudgment": {
      "type": "object",
      "required": [
        "target_capability_improvement_candidate_ref",
        "root_cause",
        "targeted_fix",
        "predicted_impact",
        "failure_class",
        "source_morphology_proof_ref",
        "private_residue_decision_ref",
        "target_runtime_read_model_consumption_ref",
        "failure_evidence_refs",
        "target_editable_surface_refs",
        "forbidden_surfaces",
        "expected_behavior_delta",
        "verification_refs",
        "reviewer_refs",
        "owner_route_refs",
        "no_forbidden_write_proof_refs",
        "patch_traceability_refs"
      ],
      "properties": {
        "target_capability_improvement_candidate_ref": { "$ref": "#/$defs/nonEmptyString" },
        "root_cause": { "$ref": "#/$defs/nonEmptyString" },
        "targeted_fix": { "$ref": "#/$defs/nonEmptyStringArray" },
        "predicted_impact": { "$ref": "#/$defs/nonEmptyString" },
        "failure_class": {
          "enum": [
            "stage-route",
            "specialist-skill",
            "tool-connector",
            "quality-gate",
            "read-model-currentness",
            "authority-boundary",
            "app-observability"
          ]
        },
        "source_morphology_proof_ref": { "$ref": "#/$defs/nonEmptyString" },
        "private_residue_decision_ref": { "$ref": "#/$defs/nonEmptyString" },
        "target_runtime_read_model_consumption_ref": { "$ref": "#/$defs/nonEmptyString" },
        "failure_evidence_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "target_editable_surface_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "forbidden_surfaces": { "$ref": "#/$defs/nonEmptyStringArray" },
        "expected_behavior_delta": { "$ref": "#/$defs/nonEmptyString" },
        "verification_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "reviewer_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "owner_route_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "no_forbidden_write_proof_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "patch_traceability_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "efficiency_non_regression_refs": {
          "type": "object",
          "properties": {
            "quality_floor_refs": { "$ref": "#/$defs/stringArray" },
            "latency_baseline_refs": { "$ref": "#/$defs/stringArray" },
            "usage_cost_refs": { "$ref": "#/$defs/stringArray" },
            "cache_reuse_refs": { "$ref": "#/$defs/stringArray" },
            "target_verification_refs": { "$ref": "#/$defs/stringArray" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "developerPatchSemanticRequest": {
      "type": "object",
      "required": [
        "request_id",
        "source_agent_lab_result_ref",
        "foundry_lab_execution_receipt_ref",
        "agent_building_judgment",
        "source_refs",
        "reviewer_refs",
        "candidate_refs"
      ],
      "properties": {
        "request_id": { "$ref": "#/$defs/nonEmptyString" },
        "source_agent_lab_result_ref": { "$ref": "#/$defs/nonEmptyString" },
        "foundry_lab_execution_receipt_ref": { "$ref": "#/$defs/nonEmptyString" },
        "agent_building_judgment": { "$ref": "#/$defs/developerPatchJudgment" },
        "source_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "reviewer_refs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "candidate_refs": { "$ref": "#/$defs/nonEmptyStringArray" }
      },
      "additionalProperties": false
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "semantic_scope",
        "work_order_materialization_owner",
        "work_order_lifecycle_owner",
        "target_worktree_lifecycle_owner",
        "target_owner_closeout_owner",
        "producer_writes_framework_request_bundle",
        "producer_assigns_work_order_id",
        "producer_manages_executor_lease",
        "producer_manages_target_worktree",
        "producer_executes_work_order",
        "producer_writes_work_order_receipt",
        "producer_writes_target_owner_closeout"
      ],
      "properties": {
        "semantic_scope": { "const": "agent_building_request_only" },
        "work_order_materialization_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "work_order_lifecycle_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_worktree_lifecycle_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_owner_closeout_owner": { "const": "target-domain" },
        "producer_writes_framework_request_bundle": { "const": false },
        "producer_assigns_work_order_id": { "const": false },
        "producer_manages_executor_lease": { "const": false },
        "producer_manages_target_worktree": { "const": false },
        "producer_executes_work_order": { "const": false },
        "producer_writes_work_order_receipt": { "const": false },
        "producer_writes_target_owner_closeout": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
