{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/standard-agent-developer-proof-request.producer.schema.json",
  "title": "OMA Standard Agent Developer Proof Request Producer",
  "description": "The single OMA-authored request for OPL-owned profile, scaffold, interface, package-manifest, and profile-conformance developer proofs. The request is not execution evidence.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "request_id",
    "request_ref",
    "request_owner",
    "execution_owner",
    "status",
    "target_identity",
    "inputs",
    "operations",
    "required_receipt_surface_kind",
    "receipt_contract_ref",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_standard_agent_developer_proof_request" },
    "version": { "const": "opl-standard-agent-developer-proof-request.v1" },
    "request_id": { "$ref": "#/$defs/nonEmptyString" },
    "request_ref": { "$ref": "#/$defs/nonEmptyString" },
    "request_owner": { "const": "opl-meta-agent" },
    "execution_owner": { "const": "one-person-lab/OPL Framework" },
    "status": { "const": "pending_framework_receipt" },
    "target_identity": { "$ref": "#/$defs/targetIdentity" },
    "inputs": {
      "type": "object",
      "required": [
        "profile_inspect_select",
        "scaffold_materialize_validate",
        "generated_interfaces",
        "package_manifest_validate",
        "profile_conformance"
      ],
      "properties": {
        "profile_inspect_select": {
          "type": "object",
          "required": [
            "target_brief",
            "intent_signals",
            "requested_profile_refs",
            "reference_design_source_refs",
            "reference_design_pattern_packet_refs",
            "research_source_refs",
            "research_synthesis_refs"
          ],
          "properties": {
            "target_brief": { "type": "string" },
            "intent_signals": { "$ref": "#/$defs/stringArray" },
            "requested_profile_refs": { "$ref": "#/$defs/stringArray" },
            "reference_design_source_refs": { "$ref": "#/$defs/stringArray" },
            "reference_design_pattern_packet_refs": { "$ref": "#/$defs/stringArray" },
            "research_source_refs": { "$ref": "#/$defs/stringArray" },
            "research_synthesis_refs": { "$ref": "#/$defs/stringArray" }
          },
          "additionalProperties": false
        },
        "scaffold_materialize_validate": {
          "type": "object",
          "required": [
            "scaffold_materialization_request_ref",
            "target_repo_ref",
            "stage_decomposition_closeout_ref",
            "agent_skeleton_build_closeout_ref",
            "profile_result_binding_ref"
          ],
          "properties": {
            "scaffold_materialization_request_ref": { "$ref": "#/$defs/nonEmptyString" },
            "target_repo_ref": { "$ref": "#/$defs/nonEmptyString" },
            "stage_decomposition_closeout_ref": { "$ref": "#/$defs/nonEmptyString" },
            "agent_skeleton_build_closeout_ref": { "$ref": "#/$defs/nonEmptyString" },
            "profile_result_binding_ref": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": false
        },
        "generated_interfaces": {
          "type": "object",
          "required": ["target_repo_ref", "scaffold_proof_binding_ref"],
          "properties": {
            "target_repo_ref": { "$ref": "#/$defs/nonEmptyString" },
            "scaffold_proof_binding_ref": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": false
        },
        "package_manifest_validate": {
          "type": "object",
          "required": [
            "package_manifest_ref",
            "scaffold_proof_binding_ref",
            "trust_tier",
            "source_kind"
          ],
          "properties": {
            "package_manifest_ref": { "$ref": "#/$defs/nonEmptyString" },
            "scaffold_proof_binding_ref": { "$ref": "#/$defs/nonEmptyString" },
            "trust_tier": { "const": "third_party_unverified" },
            "source_kind": { "const": "local_file" }
          },
          "additionalProperties": false
        },
        "profile_conformance": {
          "type": "object",
          "required": [
            "target_repo_ref",
            "mode",
            "profile_id",
            "not_applicable_reason",
            "profile_result_binding_ref"
          ],
          "properties": {
            "target_repo_ref": { "$ref": "#/$defs/nonEmptyString" },
            "mode": { "enum": ["validate", "not_applicable"] },
            "profile_id": { "type": ["string", "null"] },
            "not_applicable_reason": { "type": ["string", "null"] },
            "profile_result_binding_ref": { "$ref": "#/$defs/nonEmptyString" }
          },
          "allOf": [
            {
              "if": { "properties": { "mode": { "const": "validate" } } },
              "then": { "properties": { "not_applicable_reason": { "const": null } } }
            },
            {
              "if": { "properties": { "mode": { "const": "not_applicable" } } },
              "then": {
                "properties": {
                  "profile_id": { "const": null },
                  "not_applicable_reason": { "$ref": "#/$defs/nonEmptyString" }
                }
              }
            }
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "operations": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        { "$ref": "#/$defs/profileInspectSelectOperation" },
        { "$ref": "#/$defs/scaffoldMaterializeValidateOperation" },
        { "$ref": "#/$defs/generatedInterfacesOperation" },
        { "$ref": "#/$defs/packageManifestValidateOperation" },
        { "$ref": "#/$defs/profileConformanceOperation" }
      ],
      "items": false
    },
    "required_receipt_surface_kind": {
      "const": "opl_standard_agent_developer_proof_receipt"
    },
    "receipt_contract_ref": {
      "const": "contracts/schemas/standard-agent-developer-proof-receipt.consumer.schema.json"
    },
    "authority_boundary": {
      "type": "object",
      "required": [
        "oma_authors_request_and_consumes_receipt_only",
        "oma_executes_framework_operations",
        "opl_owns_operation_execution_and_receipt",
        "request_is_execution_receipt",
        "request_can_claim_materialization_or_validation",
        "opl_can_write_target_domain_truth",
        "opl_can_authorize_target_quality_or_export"
      ],
      "properties": {
        "oma_authors_request_and_consumes_receipt_only": { "const": true },
        "oma_executes_framework_operations": { "const": false },
        "opl_owns_operation_execution_and_receipt": { "const": true },
        "request_is_execution_receipt": { "const": false },
        "request_can_claim_materialization_or_validation": { "const": false },
        "opl_can_write_target_domain_truth": { "const": false },
        "opl_can_authorize_target_quality_or_export": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "targetIdentity": {
      "type": "object",
      "required": ["domain_id", "target_agent_ref"],
      "properties": {
        "domain_id": { "$ref": "#/$defs/nonEmptyString" },
        "target_agent_ref": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "object",
      "required": [
        "operation_id",
        "execution_owner",
        "input_refs",
        "depends_on",
        "required_output_ref"
      ],
      "properties": {
        "operation_id": {
          "enum": [
            "profile_inspect_select",
            "scaffold_materialize_validate",
            "generated_interfaces",
            "package_manifest_validate",
            "profile_conformance"
          ]
        },
        "execution_owner": { "const": "one-person-lab/OPL Framework" },
        "input_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "uniqueItems": true
        },
        "depends_on": {
          "type": "array",
          "items": {
            "enum": [
              "profile_inspect_select",
              "scaffold_materialize_validate",
              "generated_interfaces",
              "package_manifest_validate",
              "profile_conformance"
            ]
          },
          "uniqueItems": true
        },
        "required_output_ref": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "profileInspectSelectOperation": {
      "allOf": [
        { "$ref": "#/$defs/operation" },
        { "properties": { "operation_id": { "const": "profile_inspect_select" }, "depends_on": { "const": [] } } }
      ]
    },
    "scaffoldMaterializeValidateOperation": {
      "allOf": [
        { "$ref": "#/$defs/operation" },
        { "properties": { "operation_id": { "const": "scaffold_materialize_validate" }, "depends_on": { "const": ["profile_inspect_select"] } } }
      ]
    },
    "generatedInterfacesOperation": {
      "allOf": [
        { "$ref": "#/$defs/operation" },
        { "properties": { "operation_id": { "const": "generated_interfaces" }, "depends_on": { "const": ["scaffold_materialize_validate"] } } }
      ]
    },
    "packageManifestValidateOperation": {
      "allOf": [
        { "$ref": "#/$defs/operation" },
        { "properties": { "operation_id": { "const": "package_manifest_validate" }, "depends_on": { "const": ["scaffold_materialize_validate"] } } }
      ]
    },
    "profileConformanceOperation": {
      "allOf": [
        { "$ref": "#/$defs/operation" },
        { "properties": { "operation_id": { "const": "profile_conformance" }, "depends_on": { "const": ["profile_inspect_select", "scaffold_materialize_validate"] } } }
      ]
    }
  },
  "additionalProperties": false
}
