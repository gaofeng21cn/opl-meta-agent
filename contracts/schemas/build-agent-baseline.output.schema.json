{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/build-agent-baseline.output.schema.json",
  "title": "Build Agent Baseline Output",
  "description": "A materialized target Agent Pack and declarative OPL Foundry Lab evaluation handoff. It is not an Agent Lab result, owner receipt, or readiness verdict.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "status",
    "product_id",
    "meta_agent_kind",
    "target_agent",
    "artifacts",
    "opl_agent_package_manifest_validation",
    "opl_generated_interfaces",
    "opl_profile_conformance",
    "stage_decomposition_attempt",
    "agent_building_judgment",
    "foundry_lab_handoff",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_meta_agent_candidate_package_handoff"
    },
    "version": {
      "const": "opl-meta-agent.candidate-package-handoff.v1"
    },
    "status": {
      "const": "candidate_package_materialized_ready_for_opl_foundry_lab_evaluation"
    },
    "product_id": {
      "const": "opl-meta-agent"
    },
    "meta_agent_kind": {
      "const": "opl_compatible_meta_agent"
    },
    "target_agent": {
      "type": "object",
      "required": [
        "domain_id",
        "repo_dir",
        "scaffold_status",
        "scaffold_validation_status",
        "generated_interface_status",
        "domain_pack_status",
        "stage_decomposition_status"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repo_dir": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "required": [
        "stage_decomposition_attempt_receipt_path",
        "stage_decomposition_closeout_packet_path",
        "agent_lab_suite_seed_path",
        "foundry_lab_work_order_path",
        "opl_agent_package_manifest_path",
        "target_agent_capability_map_path",
        "target_agent_primary_skill_path",
        "agent_build_receipt_path",
        "agent_build_receipt_ref"
      ],
      "properties": {
        "stage_decomposition_attempt_receipt_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stage_decomposition_closeout_packet_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_lab_suite_seed_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "foundry_lab_work_order_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "opl_agent_package_manifest_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_capability_map_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_primary_skill_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_build_receipt_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_build_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "opl_agent_package_manifest_validation": {
      "type": "object"
    },
    "opl_generated_interfaces": {
      "type": "object"
    },
    "opl_profile_conformance": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "passed",
            "not_applicable"
          ]
        }
      },
      "additionalProperties": true
    },
    "stage_decomposition_attempt": {
      "type": "object"
    },
    "agent_building_judgment": {
      "type": "object",
      "required": [
        "ai_reviewer_evaluation_ref",
        "verdict",
        "source_refs",
        "direct_evidence_refs"
      ],
      "additionalProperties": true
    },
    "foundry_lab_handoff": {
      "type": "object",
      "required": [
        "suite_seed",
        "work_order"
      ],
      "properties": {
        "suite_seed": {
          "$ref": "#/$defs/suiteSeed"
        },
        "work_order": {
          "$ref": "#/$defs/workOrder"
        }
      },
      "additionalProperties": false
    },
    "authority_boundary": {
      "$ref": "#/$defs/authorityBoundary"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "targetIdentity": {
      "type": "object",
      "required": [
        "domain_id",
        "target_agent_ref",
        "descriptor_ref"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "descriptor_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "suiteSeed": {
      "type": "object",
      "required": [
        "surface_kind",
        "version",
        "suite_id",
        "suite_kind",
        "execution_owner",
        "target_agent_ref",
        "target_agent_descriptor_ref",
        "tasks"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_meta_agent_agent_lab_suite_seed"
        },
        "version": {
          "const": "opl-meta-agent.agent-lab-suite-seed.v1"
        },
        "execution_owner": {
          "const": "one-person-lab/OPL Foundry Lab"
        },
        "target_agent_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_descriptor_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "task_id",
              "domain_id",
              "target_agent_ref",
              "target_agent_descriptor_ref",
              "recovery_probe_specs",
              "trajectory_plan",
              "scorecard_spec",
              "improvement_candidate_seed",
              "promotion_gate_request"
            ],
            "properties": {
              "domain_id": {
                "const": "opl-meta-agent"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "workOrder": {
      "type": "object",
      "required": [
        "surface_kind",
        "version",
        "work_order_id",
        "work_order_kind",
        "status",
        "execution_owner",
        "target_agent",
        "suite_seed",
        "consumer_dependency",
        "execution_aperture",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_meta_agent_foundry_lab_work_order_candidate"
        },
        "version": {
          "const": "opl-meta-agent.foundry-lab-work-order-candidate.v1"
        },
        "status": {
          "const": "ready_for_opl_foundry_lab_evaluation"
        },
        "execution_owner": {
          "const": "one-person-lab/OPL Foundry Lab"
        },
        "target_agent": {
          "$ref": "#/$defs/targetIdentity"
        },
        "consumer_dependency": {
          "type": "object",
          "required": [
            "status",
            "owner",
            "required_consumer_role"
          ],
          "properties": {
            "status": {
              "const": "available"
            },
            "owner": {
              "const": "one-person-lab/OPL Foundry Lab"
            },
            "required_consumer_role": {
              "const": "compile_evaluation_work_order_to_agent_lab_suite_and_execute"
            }
          },
          "additionalProperties": false
        },
        "execution_aperture": {
          "type": "object",
          "required": [
            "action_ref",
            "work_order_lifecycle_owner",
            "result_ledger_owner",
            "target_owner_closeout_owner"
          ],
          "properties": {
            "action_ref": {
              "const": "opl agent-lab evaluation-work-order execute --work-order <work-order.json> --output <dir>"
            },
            "work_order_lifecycle_owner": {
              "const": "one-person-lab/OPL Foundry Lab"
            },
            "result_ledger_owner": {
              "const": "one-person-lab/OPL Foundry Lab"
            },
            "target_owner_closeout_owner": {
              "const": "target-domain"
            }
          },
          "additionalProperties": false
        },
        "authority_boundary": {
          "$ref": "#/$defs/authorityBoundary"
        }
      },
      "additionalProperties": true
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "oma_can_execute_agent_lab_suite",
        "oma_can_write_agent_lab_result",
        "oma_can_write_owner_receipt_body",
        "oma_can_write_learning_candidate_ledger",
        "oma_can_write_promotion_gate",
        "oma_can_manage_work_order_lifecycle",
        "oma_can_write_target_domain_truth",
        "oma_can_write_target_domain_memory_body",
        "oma_can_mutate_target_domain_artifact_body",
        "oma_can_authorize_target_domain_quality_or_export",
        "oma_can_promote_default_agent_without_gate"
      ],
      "properties": {
        "oma_can_execute_agent_lab_suite": {
          "const": false
        },
        "oma_can_write_agent_lab_result": {
          "const": false
        },
        "oma_can_write_owner_receipt_body": {
          "const": false
        },
        "oma_can_write_learning_candidate_ledger": {
          "const": false
        },
        "oma_can_write_promotion_gate": {
          "const": false
        },
        "oma_can_manage_work_order_lifecycle": {
          "const": false
        },
        "oma_can_write_target_domain_truth": {
          "const": false
        },
        "oma_can_write_target_domain_memory_body": {
          "const": false
        },
        "oma_can_mutate_target_domain_artifact_body": {
          "const": false
        },
        "oma_can_authorize_target_domain_quality_or_export": {
          "const": false
        },
        "oma_can_promote_default_agent_without_gate": {
          "const": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
