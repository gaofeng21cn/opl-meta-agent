{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/build-agent-baseline.output.schema.json",
  "title": "Build Agent Baseline Output",
  "description": "A materialized target Agent Pack and declarative OPL Foundry Lab evaluation handoff. It is not an Agent Lab result, owner receipt, or readiness verdict.",
  "type": "object",
  "oneOf": [
    {
      "properties": {
        "surface_kind": { "const": "opl_meta_agent_candidate_package_handoff" },
        "version": { "const": "opl-meta-agent.candidate-package-handoff.v1" },
        "status": {
          "enum": [
            "candidate_package_materialized_ready_for_opl_foundry_lab_evaluation",
            "completed_with_quality_debt"
          ]
        },
        "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
      },
      "required": [
        "product_id",
        "meta_agent_kind",
        "target_agent",
        "artifacts",
        "opl_agent_package_manifest_validation",
        "opl_generated_interfaces",
        "opl_profile_conformance",
        "stage_decomposition_artifact",
        "agent_skeleton_build_artifact",
        "agent_building_judgment",
        "foundry_lab_handoff",
        "authority_boundary"
      ]
    },
    {
      "properties": {
        "surface_kind": { "const": "opl_meta_agent_baseline_progress" },
        "version": { "const": "opl-meta-agent.baseline-progress.v1" },
        "status": { "const": "completed_with_quality_debt" },
        "next_stage_may_start": { "const": true },
        "semantic_route_decision_owner": { "const": "decisive_codex_attempt" },
        "stage_transition_materialization_owner": { "const": "opl_stage_run_controller" }
      },
      "required": [
        "target_agent_ref",
        "quality_debt_ref",
        "stage_closeout",
        "next_stage_may_start",
        "semantic_route_decision_owner",
        "stage_transition_materialization_owner"
      ]
    }
  ],
  "required": [
    "surface_kind",
    "version",
    "status"
  ],
  "properties": {
    "surface_kind": {
      "enum": [
        "opl_meta_agent_candidate_package_handoff",
        "opl_meta_agent_baseline_progress"
      ]
    },
    "version": {
      "enum": [
        "opl-meta-agent.candidate-package-handoff.v1",
        "opl-meta-agent.baseline-progress.v1"
      ]
    },
    "status": {
      "enum": [
        "candidate_package_materialized_ready_for_opl_foundry_lab_evaluation",
        "completed_with_quality_debt"
      ]
    },
    "product_id": {
      "const": "opl-meta-agent"
    },
    "meta_agent_kind": {
      "const": "opl_compatible_meta_agent"
    },
    "domain_pack_status": { "type": "string" },
    "prompt_policy_refs": { "$ref": "#/$defs/stringArray" },
    "skill_policy_refs": { "$ref": "#/$defs/stringArray" },
    "quality_gate_refs": { "$ref": "#/$defs/stringArray" },
    "knowledge_policy_refs": { "$ref": "#/$defs/stringArray" },
    "source_domain_pack": { "type": "object" },
    "target_agent_domain_pack": { "type": "object" },
    "target_agent": {
      "type": "object",
      "required": [
        "domain_id",
        "repo_dir",
        "scaffold_status",
        "scaffold_validation_status",
        "generated_interface_status",
        "domain_pack_status",
        "stage_decomposition_status"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repo_dir": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_label": { "type": ["string", "null"] },
        "delivery_domain": { "type": ["string", "null"] },
        "target_kind": { "type": ["string", "null"] },
        "target_brief": { "type": ["string", "null"] },
        "intent_signals": { "type": ["array", "null"], "items": { "type": "string" } },
        "selected_opl_profile_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "profile_selection_rationale": { "type": ["string", "null"] },
        "profile_requirement_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_source_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_pattern_notes": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_pattern_packet_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "research_source_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "expert_practice_notes": { "type": ["array", "null"], "items": { "type": "string" } },
        "research_synthesis_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "target_agent_ref": { "type": "string" },
        "descriptor_ref": { "type": "string" },
        "descriptor": { "type": ["object", "null"] },
        "scaffold_status": { "type": "string" },
        "scaffold_validation_status": { "type": "string" },
        "generated_interface_status": { "type": "string" },
        "domain_pack_status": { "type": "string" },
        "stage_decomposition_status": { "const": "typed_closeout_received" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": [
        "stage_decomposition_closeout_packet_ref",
        "agent_skeleton_build_closeout_packet_ref",
        "scaffold_materialization_request_path",
        "developer_proof_request_path",
        "developer_proof_request_ref",
        "developer_proof_receipt_ref",
        "opl_agent_package_manifest_path",
        "target_agent_capability_map_path",
        "target_agent_primary_skill_path",
        "agent_build_receipt_path",
        "agent_build_receipt_ref"
      ],
      "properties": {
        "stage_decomposition_closeout_packet_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_skeleton_build_closeout_packet_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scaffold_materialization_request_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "developer_proof_request_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "developer_proof_request_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "developer_proof_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "opl_agent_package_manifest_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_capability_map_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_primary_skill_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_build_receipt_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_build_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "opl_agent_package_manifest_validation": {
      "type": "object"
    },
    "opl_generated_interfaces": {
      "type": "object"
    },
    "opl_profile_conformance": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "passed",
            "not_applicable"
          ]
        }
      },
      "additionalProperties": true
    },
    "stage_decomposition_artifact": {
      "type": "object"
    },
    "agent_skeleton_build_artifact": {
      "type": "object"
    },
    "target_agent_ref": { "$ref": "#/$defs/nonEmptyString" },
    "quality_debt_ref": { "$ref": "#/$defs/nonEmptyString" },
    "missing_specialized_input_stages": { "$ref": "#/$defs/stringArray" },
    "materialized_artifact_refs": { "$ref": "#/$defs/stringArray" },
    "stage_closeout": { "type": "object" },
    "developer_proof_request": { "type": "object" },
    "developer_proof_request_ref": { "$ref": "#/$defs/nonEmptyString" },
    "developer_proof_request_path": { "$ref": "#/$defs/nonEmptyString" },
    "developer_proof_receipt_ref": { "$ref": "#/$defs/nonEmptyString" },
    "developer_proof_receipt_state": {
      "enum": ["pending_framework_receipt", "invalid_receipt_fail_closed"]
    },
    "required_developer_proof_receipt_surface_kind": {
      "const": "opl_standard_agent_developer_proof_receipt"
    },
    "developer_proof_failure": {
      "type": "object",
      "required": [
        "failure_kind",
        "message",
        "materialization_or_validation_accepted_as_evidence"
      ],
      "properties": {
        "failure_kind": { "const": "developer_proof_contract_mismatch" },
        "message": { "$ref": "#/$defs/nonEmptyString" },
        "materialization_or_validation_accepted_as_evidence": { "const": false }
      },
      "additionalProperties": false
    },
    "next_stage_may_start": { "type": "boolean" },
    "semantic_route_decision_owner": { "const": "decisive_codex_attempt" },
    "stage_transition_materialization_owner": { "const": "opl_stage_run_controller" },
    "action_id": {
      "const": "build-agent-baseline"
    },
    "route_policy": {
      "const": "ai_selected_progress_route"
    },
    "completed_stage_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "next_stage_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "stage_run_owner": {
      "const": "one-person-lab"
    },
    "receipt_emitted": {
      "type": "boolean"
    },
    "agent_building_judgment": {
      "type": "object",
      "required": [
        "ai_reviewer_evaluation_ref",
        "verdict",
        "source_refs",
        "direct_evidence_refs"
      ],
      "additionalProperties": true
    },
    "foundry_lab_handoff": {
      "type": "object",
      "required": [
        "materialization_request"
      ],
      "properties": {
        "materialization_request": {
          "$ref": "#/$defs/workOrderMaterializationRequest"
        }
      },
      "additionalProperties": false
    },
    "authority_boundary": {
      "$ref": "#/$defs/authorityBoundary"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "materializationTargetAgent": {
      "type": "object",
      "required": [
        "domain_id",
        "repo_dir",
        "target_agent_ref",
        "descriptor_ref"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repo_dir": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "descriptor_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "foundryEvaluationSemanticRequest": {
      "type": "object",
      "required": [
        "request_id",
        "suite_id",
        "suite_kind",
        "task_intents",
        "source_refs",
        "reviewer_refs",
        "candidate_refs"
      ],
      "properties": {
        "request_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "suite_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "suite_kind": {
          "enum": [
            "agent_lab_external_suite",
            "agent_production_evidence_suite"
          ]
        },
        "task_intents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "task_id",
              "domain_id",
              "task_family",
              "instructions_ref",
              "agent_entry_ref",
              "stage_refs",
              "oracle_refs",
              "scorer_refs",
              "metric_refs",
              "evidence_refs",
              "review_refs",
              "quality_gate_refs",
              "trajectory_ref",
              "requested_run_ref",
              "artifact_refs",
              "receipt_refs",
              "scorecard_ref",
              "improvement_candidate",
              "promotion_gate_ref"
            ],
            "properties": {
              "task_id": { "$ref": "#/$defs/nonEmptyString" },
              "domain_id": {
                "const": "opl-meta-agent"
              },
              "task_family": { "$ref": "#/$defs/nonEmptyString" },
              "instructions_ref": { "$ref": "#/$defs/nonEmptyString" },
              "agent_entry_ref": { "$ref": "#/$defs/nonEmptyString" },
              "stage_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "oracle_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "scorer_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "metric_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "review_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "quality_gate_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "trajectory_ref": { "$ref": "#/$defs/nonEmptyString" },
              "requested_run_ref": { "$ref": "#/$defs/nonEmptyString" },
              "artifact_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "receipt_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "scorecard_ref": { "$ref": "#/$defs/nonEmptyString" },
              "improvement_candidate": {
                "type": "object",
                "required": [
                  "candidate_ref",
                  "candidate_kind",
                  "target_ref",
                  "allowed_change_scope"
                ],
                "properties": {
                  "candidate_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "candidate_kind": { "$ref": "#/$defs/nonEmptyString" },
                  "target_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "allowed_change_scope": {
                    "enum": ["candidate_config_only", "branch_only", "manual_review_required"]
                  }
                },
                "additionalProperties": false
              },
              "promotion_gate_ref": { "$ref": "#/$defs/nonEmptyString" },
              "promotion_gate_required_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "regression_suite_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              }
            },
            "additionalProperties": false
          }
        },
        "production_evidence_gate_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "source_refs": { "$ref": "#/$defs/stringArray" },
        "reviewer_refs": { "$ref": "#/$defs/stringArray" },
        "candidate_refs": { "$ref": "#/$defs/stringArray" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "suite_kind": { "const": "agent_production_evidence_suite" } },
            "required": ["suite_kind"]
          },
          "then": { "required": ["production_evidence_gate_ids"] }
        }
      ],
      "additionalProperties": false
    },
    "workOrderMaterializationRequest": {
      "type": "object",
      "required": [
        "surface_kind",
        "version",
        "canonical_schema_ref",
        "request_kind",
        "request_owner",
        "producer_agent_id",
        "execution_owner",
        "target_agent",
        "semantic_request",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": { "const": "opl_work_order_materialization_request" },
        "version": { "const": "opl-work-order-materialization-request.v2" },
        "canonical_schema_ref": {
          "const": "contracts/opl-framework/work-order-materialization-request.schema.json"
        },
        "request_kind": { "const": "foundry_evaluation" },
        "request_owner": { "const": "oma" },
        "producer_agent_id": { "const": "oma" },
        "execution_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_agent": { "$ref": "#/$defs/materializationTargetAgent" },
        "semantic_request": { "$ref": "#/$defs/foundryEvaluationSemanticRequest" },
        "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
      },
      "additionalProperties": false
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "semantic_scope",
        "work_order_materialization_owner",
        "work_order_lifecycle_owner",
        "target_worktree_lifecycle_owner",
        "target_owner_closeout_owner",
        "producer_writes_framework_request_bundle",
        "producer_assigns_work_order_id",
        "producer_manages_executor_lease",
        "producer_manages_target_worktree",
        "producer_executes_work_order",
        "producer_writes_work_order_receipt",
        "producer_writes_target_owner_closeout"
      ],
      "properties": {
        "semantic_scope": { "const": "agent_building_request_only" },
        "work_order_materialization_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "work_order_lifecycle_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_worktree_lifecycle_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_owner_closeout_owner": { "const": "target-domain" },
        "producer_writes_framework_request_bundle": { "const": false },
        "producer_assigns_work_order_id": { "const": false },
        "producer_manages_executor_lease": { "const": false },
        "producer_manages_target_worktree": { "const": false },
        "producer_executes_work_order": { "const": false },
        "producer_writes_work_order_receipt": { "const": false },
        "producer_writes_target_owner_closeout": { "const": false }
      },
      "additionalProperties": false
    },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
