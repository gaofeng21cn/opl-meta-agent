{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/build-agent-baseline.output.schema.json",
  "title": "Build Agent Baseline Output",
  "description": "A materialized target Agent Pack and declarative OPL Foundry Lab evaluation handoff. It is not an Agent Lab result, owner receipt, or readiness verdict.",
  "type": "object",
  "oneOf": [
    {
      "properties": {
        "surface_kind": { "const": "opl_meta_agent_candidate_package_handoff" },
        "version": { "const": "opl-meta-agent.candidate-package-handoff.v1" },
        "status": { "const": "candidate_package_materialized_ready_for_opl_foundry_lab_evaluation" },
        "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
      },
      "required": [
        "product_id",
        "meta_agent_kind",
        "target_agent",
        "artifacts",
        "opl_agent_package_manifest_validation",
        "opl_generated_interfaces",
        "opl_profile_conformance",
        "stage_decomposition_attempt",
        "agent_skeleton_build_attempt",
        "action_stage_route_closeout",
        "agent_building_judgment",
        "foundry_lab_handoff",
        "authority_boundary"
      ]
    },
    {
      "properties": {
        "surface_kind": { "const": "opl_meta_agent_action_stage_continuation" },
        "version": { "const": "opl-meta-agent.action-stage-continuation.v1" },
        "status": { "const": "continuation_required" },
        "receipt_emitted": { "const": false },
        "authority_boundary": { "$ref": "#/$defs/continuationAuthorityBoundary" }
      },
      "required": [
        "action_id",
        "route_policy",
        "completed_stage_refs",
        "next_stage_ref",
        "stage_run_owner",
        "receipt_emitted",
        "authority_boundary"
      ],
      "$ref": "#/$defs/buildBaselineContinuationState"
    }
  ],
  "required": [
    "surface_kind",
    "version",
    "status"
  ],
  "properties": {
    "surface_kind": {
      "enum": [
        "opl_meta_agent_candidate_package_handoff",
        "opl_meta_agent_action_stage_continuation"
      ]
    },
    "version": {
      "enum": [
        "opl-meta-agent.candidate-package-handoff.v1",
        "opl-meta-agent.action-stage-continuation.v1"
      ]
    },
    "status": {
      "enum": [
        "candidate_package_materialized_ready_for_opl_foundry_lab_evaluation",
        "continuation_required"
      ]
    },
    "product_id": {
      "const": "opl-meta-agent"
    },
    "meta_agent_kind": {
      "const": "opl_compatible_meta_agent"
    },
    "domain_pack_status": { "type": "string" },
    "prompt_policy_refs": { "$ref": "#/$defs/stringArray" },
    "skill_policy_refs": { "$ref": "#/$defs/stringArray" },
    "quality_gate_refs": { "$ref": "#/$defs/stringArray" },
    "knowledge_policy_refs": { "$ref": "#/$defs/stringArray" },
    "source_domain_pack": { "type": "object" },
    "target_agent_domain_pack": { "type": "object" },
    "target_agent": {
      "type": "object",
      "required": [
        "domain_id",
        "repo_dir",
        "scaffold_status",
        "scaffold_validation_status",
        "generated_interface_status",
        "domain_pack_status",
        "stage_decomposition_status"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repo_dir": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_label": { "type": ["string", "null"] },
        "delivery_domain": { "type": ["string", "null"] },
        "target_kind": { "type": ["string", "null"] },
        "target_brief": { "type": ["string", "null"] },
        "intent_signals": { "type": ["array", "null"], "items": { "type": "string" } },
        "selected_opl_profile_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "profile_selection_rationale": { "type": ["string", "null"] },
        "profile_requirement_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_source_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_pattern_notes": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_pattern_packet_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "research_source_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "expert_practice_notes": { "type": ["array", "null"], "items": { "type": "string" } },
        "research_synthesis_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "target_agent_ref": { "type": "string" },
        "descriptor_ref": { "type": "string" },
        "descriptor": { "type": ["object", "null"] },
        "scaffold_status": { "type": "string" },
        "scaffold_validation_status": { "type": "string" },
        "generated_interface_status": { "type": "string" },
        "domain_pack_status": { "type": "string" },
        "stage_decomposition_status": { "const": "typed_closeout_received" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": [
        "stage_decomposition_stage_run_readback_path",
        "agent_skeleton_build_stage_run_readback_path",
        "scaffold_materialization_request_path",
        "foundry_evaluation_request_path",
        "foundry_lab_work_order_path",
        "opl_agent_package_manifest_path",
        "target_agent_capability_map_path",
        "target_agent_primary_skill_path",
        "agent_build_receipt_path",
        "agent_build_receipt_ref"
      ],
      "properties": {
        "stage_decomposition_stage_run_readback_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_skeleton_build_stage_run_readback_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scaffold_materialization_request_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "foundry_evaluation_request_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "foundry_lab_work_order_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "opl_agent_package_manifest_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_capability_map_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_primary_skill_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_build_receipt_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_build_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "opl_agent_package_manifest_validation": {
      "type": "object"
    },
    "opl_generated_interfaces": {
      "type": "object"
    },
    "opl_profile_conformance": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "passed",
            "not_applicable"
          ]
        }
      },
      "additionalProperties": true
    },
    "stage_decomposition_attempt": {
      "type": "object"
    },
    "agent_skeleton_build_attempt": {
      "type": "object"
    },
    "action_stage_route_closeout": {
      "type": "object"
    },
    "action_id": {
      "const": "build-agent-baseline"
    },
    "route_policy": {
      "const": "ordered_stage_attempts_no_skip"
    },
    "completed_stage_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "next_stage_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "stage_run_owner": {
      "const": "one-person-lab"
    },
    "receipt_emitted": {
      "type": "boolean"
    },
    "agent_building_judgment": {
      "type": "object",
      "required": [
        "ai_reviewer_evaluation_ref",
        "verdict",
        "source_refs",
        "direct_evidence_refs"
      ],
      "additionalProperties": true
    },
    "foundry_lab_handoff": {
      "type": "object",
      "required": [
        "evaluation_request",
        "work_order"
      ],
      "properties": {
        "evaluation_request": {
          "$ref": "#/$defs/evaluationRequest"
        },
        "work_order": {
          "$ref": "#/$defs/workOrder"
        }
      },
      "additionalProperties": false
    },
    "authority_boundary": {
      "type": "object"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "targetIdentity": {
      "type": "object",
      "required": [
        "domain_id",
        "target_agent_ref",
        "descriptor_ref"
      ],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_agent_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "descriptor_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_label": { "type": ["string", "null"] },
        "repo_dir": { "type": ["string", "null"] },
        "delivery_domain": { "type": ["string", "null"] },
        "target_kind": { "type": ["string", "null"] },
        "target_brief": { "type": ["string", "null"] },
        "intent_signals": { "type": ["array", "null"], "items": { "type": "string" } },
        "selected_opl_profile_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "profile_selection_rationale": { "type": ["string", "null"] },
        "profile_requirement_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_source_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_pattern_notes": { "type": ["array", "null"], "items": { "type": "string" } },
        "reference_design_pattern_packet_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "research_source_refs": { "type": ["array", "null"], "items": { "type": "string" } },
        "expert_practice_notes": { "type": ["array", "null"], "items": { "type": "string" } },
        "research_synthesis_refs": { "type": ["array", "null"], "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "evaluationRequest": {
      "type": "object",
      "required": [
        "surface_kind",
        "version",
        "request_id",
        "suite_id",
        "suite_kind",
        "task_intents",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_meta_agent_foundry_evaluation_request"
        },
        "version": {
          "const": "opl-meta-agent.foundry-evaluation-request.v1"
        },
        "request_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "suite_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "suite_kind": {
          "enum": [
            "agent_lab_external_suite",
            "agent_production_evidence_suite"
          ]
        },
        "task_intents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "task_id",
              "domain_id",
              "task_family",
              "instructions_ref",
              "agent_entry_ref",
              "stage_refs",
              "oracle_refs",
              "scorer_refs",
              "metric_refs",
              "evidence_refs",
              "review_refs",
              "quality_gate_refs",
              "trajectory_ref",
              "requested_run_ref",
              "artifact_refs",
              "receipt_refs",
              "scorecard_ref",
              "improvement_candidate",
              "promotion_gate_ref"
            ],
            "properties": {
              "task_id": { "$ref": "#/$defs/nonEmptyString" },
              "domain_id": {
                "const": "opl-meta-agent"
              },
              "task_family": { "$ref": "#/$defs/nonEmptyString" },
              "instructions_ref": { "$ref": "#/$defs/nonEmptyString" },
              "agent_entry_ref": { "$ref": "#/$defs/nonEmptyString" },
              "stage_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "oracle_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "scorer_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "metric_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "review_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "quality_gate_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "trajectory_ref": { "$ref": "#/$defs/nonEmptyString" },
              "requested_run_ref": { "$ref": "#/$defs/nonEmptyString" },
              "artifact_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "receipt_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "scorecard_ref": { "$ref": "#/$defs/nonEmptyString" },
              "improvement_candidate": {
                "type": "object",
                "required": [
                  "candidate_ref",
                  "candidate_kind",
                  "target_ref",
                  "allowed_change_scope"
                ],
                "properties": {
                  "candidate_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "candidate_kind": { "$ref": "#/$defs/nonEmptyString" },
                  "target_ref": { "$ref": "#/$defs/nonEmptyString" },
                  "allowed_change_scope": {
                    "enum": ["candidate_config_only", "branch_only", "manual_review_required"]
                  }
                },
                "additionalProperties": false
              },
              "promotion_gate_ref": { "$ref": "#/$defs/nonEmptyString" },
              "promotion_gate_required_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "regression_suite_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              }
            },
            "additionalProperties": false
          }
        },
        "production_evidence_gate_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "authority_boundary": {
          "type": "object",
          "required": [
            "refs_only",
            "oma_can_execute_agent_lab_suite",
            "oma_can_write_agent_lab_result",
            "oma_can_write_owner_receipt_body",
            "oma_can_write_promotion_gate",
            "oma_can_claim_target_domain_ready",
            "oma_can_claim_target_production_ready"
          ],
          "properties": {
            "refs_only": { "const": true },
            "oma_can_execute_agent_lab_suite": { "const": false },
            "oma_can_write_agent_lab_result": { "const": false },
            "oma_can_write_owner_receipt_body": { "const": false },
            "oma_can_write_promotion_gate": { "const": false },
            "oma_can_claim_target_domain_ready": { "const": false },
            "oma_can_claim_target_production_ready": { "const": false }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "workOrder": {
      "type": "object",
      "required": [
        "surface_kind",
        "version",
        "work_order_id",
        "work_order_kind",
        "status",
        "product_id",
        "execution_owner",
        "target_agent",
        "evaluation_request",
        "source_refs",
        "reviewer_refs",
        "candidate_refs",
        "requested_operations",
        "expected_return_shapes",
        "consumer_dependency",
        "execution_aperture",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_meta_agent_foundry_lab_work_order_candidate"
        },
        "version": {
          "const": "opl-meta-agent.foundry-lab-work-order-candidate.v1"
        },
        "status": {
          "const": "ready_for_opl_foundry_lab_evaluation"
        },
        "execution_owner": {
          "const": "one-person-lab/OPL Foundry Lab"
        },
        "target_agent": {
          "$ref": "#/$defs/targetIdentity"
        },
        "evaluation_request": {
          "type": "object",
          "required": ["ref", "sha256", "request_id", "suite_id", "suite_kind"],
          "properties": {
            "ref": { "$ref": "#/$defs/nonEmptyString" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "request_id": { "$ref": "#/$defs/nonEmptyString" },
            "suite_id": { "$ref": "#/$defs/nonEmptyString" },
            "suite_kind": {
              "enum": ["agent_lab_external_suite", "agent_production_evidence_suite"]
            }
          },
          "additionalProperties": false
        },
        "consumer_dependency": {
          "type": "object",
          "required": [
            "status",
            "owner",
            "required_consumer_role"
          ],
          "properties": {
            "status": {
              "const": "available"
            },
            "owner": {
              "const": "one-person-lab/OPL Foundry Lab"
            },
            "required_consumer_role": {
              "const": "compile_evaluation_work_order_to_agent_lab_suite_and_execute"
            }
          },
          "additionalProperties": false
        },
        "execution_aperture": {
          "type": "object",
          "required": [
            "action_ref",
            "work_order_lifecycle_owner",
            "result_ledger_owner",
            "target_owner_closeout_owner"
          ],
          "properties": {
            "action_ref": {
              "const": "opl agent-lab evaluation-work-order execute --work-order <work-order.json> --output <dir>"
            },
            "work_order_lifecycle_owner": {
              "const": "one-person-lab/OPL Foundry Lab"
            },
            "result_ledger_owner": {
              "const": "one-person-lab/OPL Foundry Lab"
            },
            "target_owner_closeout_owner": {
              "const": "target-domain"
            }
          },
          "additionalProperties": false
        },
        "authority_boundary": {
          "$ref": "#/$defs/authorityBoundary"
        },
        "work_order_id": { "$ref": "#/$defs/nonEmptyString" },
        "work_order_kind": {
          "enum": [
            "agent_baseline_evaluation",
            "target_agent_takeover_evaluation",
            "target_agent_production_evidence_evaluation"
          ]
        },
        "product_id": { "const": "opl-meta-agent" },
        "source_refs": { "$ref": "#/$defs/stringArray" },
        "reviewer_refs": { "$ref": "#/$defs/stringArray" },
        "candidate_refs": { "$ref": "#/$defs/stringArray" },
        "requested_operations": { "$ref": "#/$defs/stringArray" },
        "expected_return_shapes": { "$ref": "#/$defs/stringArray" }
      },
      "additionalProperties": false
    },
    "buildBaselineContinuationState": {
      "type": "object",
      "required": ["completed_stage_refs", "next_stage_ref"],
      "properties": {
        "completed_stage_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "uniqueItems": true
        },
        "next_stage_ref": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "continuationAuthorityBoundary": {
      "type": "object",
      "required": [
        "oma_can_create_stage_run_receipt",
        "oma_can_skip_required_stage",
        "optional_stage_can_replace_required_stage",
        "continuation_is_action_completion"
      ],
      "properties": {
        "oma_can_create_stage_run_receipt": { "const": false },
        "oma_can_skip_required_stage": { "const": false },
        "optional_stage_can_replace_required_stage": { "const": false },
        "continuation_is_action_completion": { "const": false }
      },
      "additionalProperties": false
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "oma_can_execute_agent_lab_suite",
        "oma_can_write_agent_lab_result",
        "oma_can_write_owner_receipt_body",
        "oma_can_write_learning_candidate_ledger",
        "oma_can_write_promotion_gate",
        "oma_can_write_mechanism_or_scaleout_ledger",
        "oma_can_manage_work_order_lifecycle",
        "oma_can_write_target_domain_truth",
        "oma_can_write_target_domain_memory_body",
        "oma_can_mutate_target_domain_artifact_body",
        "oma_can_authorize_target_domain_quality_or_export",
        "oma_can_claim_target_domain_ready",
        "oma_can_claim_target_production_ready",
        "oma_can_promote_default_agent_without_gate"
      ],
      "properties": {
        "oma_can_execute_agent_lab_suite": {
          "const": false
        },
        "oma_can_write_agent_lab_result": {
          "const": false
        },
        "oma_can_write_owner_receipt_body": {
          "const": false
        },
        "oma_can_write_learning_candidate_ledger": {
          "const": false
        },
        "oma_can_write_promotion_gate": {
          "const": false
        },
        "oma_can_write_mechanism_or_scaleout_ledger": {
          "const": false
        },
        "oma_can_manage_work_order_lifecycle": {
          "const": false
        },
        "oma_can_write_target_domain_truth": {
          "const": false
        },
        "oma_can_write_target_domain_memory_body": {
          "const": false
        },
        "oma_can_mutate_target_domain_artifact_body": {
          "const": false
        },
        "oma_can_authorize_target_domain_quality_or_export": {
          "const": false
        },
        "oma_can_claim_target_domain_ready": {
          "const": false
        },
        "oma_can_claim_target_production_ready": {
          "const": false
        },
        "oma_can_promote_default_agent_without_gate": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
