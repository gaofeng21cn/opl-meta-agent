{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/execute-external-work-order.input.schema.json",
  "title": "Execute External Work Order Input",
  "description": "Inputs for validating an OMA developer patch work order and delegating it to the OPL work-order primitive.",
  "type": "object",
  "required": [
    "work_order_path"
  ],
  "properties": {
    "work_order_path": {
      "type": "string",
      "minLength": 1
    },
    "output_path": {
      "type": "string",
      "minLength": 1
    },
    "opl_bin": {
      "type": "string",
      "minLength": 1
    },
    "opl_work_order_passthrough_args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
