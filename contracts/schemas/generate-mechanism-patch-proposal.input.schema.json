{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/generate-mechanism-patch-proposal.input.schema.json",
  "title": "Generate Mechanism Patch Proposal Input",
  "description": "Refs required by the proposal-only mechanism patch authority function.",
  "type": "object",
  "required": [
    "mechanism_ref",
    "segment_run_ref",
    "evidence_delta_ref",
    "next_mechanism_candidate_ref"
  ],
  "properties": {
    "mechanism_ref": {
      "type": "string",
      "minLength": 1
    },
    "segment_run_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_delta_ref": {
      "type": "string",
      "minLength": 1
    },
    "next_mechanism_candidate_ref": {
      "type": "string",
      "minLength": 1
    },
    "editable_surfaces": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "observe_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "diagnose_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "edit_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  },
  "additionalProperties": false
}
