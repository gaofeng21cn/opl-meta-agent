{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/build-agent-baseline.input.schema.json",
  "title": "Build Agent Baseline Input",
  "description": "Inputs accepted by the build-agent-baseline action after natural-language intent extraction.",
  "type": "object",
  "required": [
    "domain_id",
    "ai_reviewer_evaluation"
  ],
  "properties": {
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "opl_bin": {
      "type": "string",
      "minLength": 1
    },
    "ai_reviewer_evaluation": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the structured independent AI reviewer evaluation."
    },
    "domain_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "domain_label": {
      "type": "string",
      "minLength": 1
    },
    "delivery_domain": {
      "type": "string",
      "minLength": 1
    },
    "target_brief": {
      "type": "string",
      "minLength": 1
    },
    "intent_signals": {
      "$ref": "#/$defs/nonEmptyStringArray",
      "description": "Canonical OPL profile selector signals extracted from the original intent; they only affect lower-bound profile matching."
    },
    "selected_opl_profile_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "profile_selection_rationale": {
      "type": "string",
      "minLength": 1
    },
    "profile_requirement_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "reference_design_source_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "reference_design_pattern_notes": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "reference_design_pattern_packet_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "research_source_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "expert_practice_notes": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "research_synthesis_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "stage_runner": {
      "type": "string",
      "enum": [
        "live",
        "fixture"
      ],
      "default": "live"
    },
    "stage_closeout_packet": {
      "type": "string",
      "minLength": 1
    }
  },
  "anyOf": [
    {
      "required": [
        "selected_opl_profile_refs"
      ],
      "properties": {
        "selected_opl_profile_refs": true
      }
    },
    {
      "required": [
        "reference_design_source_refs"
      ],
      "properties": {
        "reference_design_source_refs": true
      }
    },
    {
      "required": [
        "reference_design_pattern_notes"
      ],
      "properties": {
        "reference_design_pattern_notes": true
      }
    },
    {
      "required": [
        "reference_design_pattern_packet_refs"
      ],
      "properties": {
        "reference_design_pattern_packet_refs": true
      }
    },
    {
      "required": [
        "research_source_refs"
      ],
      "properties": {
        "research_source_refs": true
      }
    },
    {
      "required": [
        "expert_practice_notes"
      ],
      "properties": {
        "expert_practice_notes": true
      }
    },
    {
      "required": [
        "research_synthesis_refs"
      ],
      "properties": {
        "research_synthesis_refs": true
      }
    }
  ],
  "allOf": [
    {
      "if": {
        "required": [
          "selected_opl_profile_refs"
        ]
      },
      "then": {
        "required": [
          "profile_selection_rationale"
        ],
        "properties": {
          "profile_selection_rationale": true
        }
      }
    },
    {
      "if": {
        "required": [
          "stage_runner"
        ],
        "properties": {
          "stage_runner": {
            "const": "fixture"
          }
        }
      },
      "then": {
        "required": [
          "stage_closeout_packet"
        ],
        "properties": {
          "stage_closeout_packet": true
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  },
  "additionalProperties": false
}
