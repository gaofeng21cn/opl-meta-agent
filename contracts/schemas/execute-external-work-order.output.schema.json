{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/execute-external-work-order.output.schema.json",
  "title": "Execute External Work Order Output",
  "description": "Readback proving OMA delegated a validated work order to OPL without owning target lifecycle or owner receipt authority.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "status",
    "owner",
    "work_order_ref",
    "work_order_path",
    "work_order_readback",
    "opl_work_order_command",
    "authority_boundary",
    "opl_result",
    "opl_result_currentness"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_meta_agent_external_work_order_execution_delegation"
    },
    "version": {
      "const": "opl-meta-agent.external-work-order-execution-delegation.v1"
    },
    "status": {
      "const": "delegated_to_opl_work_order_primitive"
    },
    "owner": {
      "const": "opl-meta-agent"
    },
    "work_order_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "work_order_path": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "work_order_readback": {
      "type": "object",
      "required": [
        "agent_evolution_decision_ref",
        "failure_class",
        "target_owner_route",
        "verification_refs",
        "owner_closeout_readback"
      ],
      "properties": {
        "agent_evolution_decision_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "failure_class": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_owner_route": {
          "type": "object",
          "required": [
            "target_agent_id",
            "owner_route_ref",
            "route_refs",
            "currentness_ref"
          ],
          "properties": {
            "target_agent_id": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "owner_route_ref": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "route_refs": {
              "$ref": "#/$defs/nonEmptyStringArray"
            },
            "currentness_ref": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "additionalProperties": false
        },
        "verification_refs": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "owner_closeout_readback": {
          "type": "object",
          "required": [
            "owner",
            "target_owner_receipt_or_typed_blocker_ref",
            "target_owner_closeout_refs",
            "oma_can_write_target_owner_receipt_body",
            "can_write_target_domain_truth"
          ],
          "properties": {
            "owner": {
              "const": "target-domain via OPL"
            },
            "target_owner_receipt_or_typed_blocker_ref": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "target_owner_closeout_refs": {
              "$ref": "#/$defs/nonEmptyStringArray"
            },
            "oma_can_write_target_owner_receipt_body": {
              "const": false
            },
            "can_write_target_domain_truth": {
              "const": false
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "opl_work_order_command": {
      "type": "object",
      "required": [
        "command",
        "opl_bin",
        "args",
        "passthrough_args"
      ],
      "properties": {
        "command": {
          "const": "work-order execute"
        },
        "opl_bin": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "args": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "passthrough_args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "authority_boundary": {
      "type": "object",
      "required": [
        "can_manage_target_worktree_lifecycle",
        "can_absorb_target_branch",
        "can_clean_target_worktree",
        "can_invoke_target_owner_closeout_hook",
        "can_write_target_owner_receipt_body",
        "can_write_target_domain_truth",
        "can_write_target_domain_memory_body",
        "can_mutate_target_domain_artifact_body",
        "can_authorize_target_domain_quality_or_export",
        "can_promote_default_agent_without_gate"
      ],
      "properties": {
        "can_manage_target_worktree_lifecycle": {
          "const": false
        },
        "can_absorb_target_branch": {
          "const": false
        },
        "can_clean_target_worktree": {
          "const": false
        },
        "can_invoke_target_owner_closeout_hook": {
          "const": false
        },
        "can_write_target_owner_receipt_body": {
          "const": false
        },
        "can_write_target_domain_truth": {
          "const": false
        },
        "can_write_target_domain_memory_body": {
          "const": false
        },
        "can_mutate_target_domain_artifact_body": {
          "const": false
        },
        "can_authorize_target_domain_quality_or_export": {
          "const": false
        },
        "can_promote_default_agent_without_gate": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "opl_result": {
      "type": "object",
      "required": [
        "surface_kind",
        "status"
      ],
      "properties": {
        "surface_kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "opl_result_currentness": {
      "type": "object",
      "required": [
        "closeout_refs_verified",
        "structural_closeout_verified",
        "typed_blocker_refs_present",
        "dry_run_ready",
        "opl_result_envelope"
      ],
      "properties": {
        "closeout_refs_verified": {
          "type": "boolean"
        },
        "structural_closeout_verified": {
          "type": "boolean"
        },
        "typed_blocker_refs_present": {
          "type": "boolean"
        },
        "dry_run_ready": {
          "type": "boolean"
        },
        "opl_result_envelope": {
          "type": "string",
          "enum": [
            "direct",
            "g2_work_order_execution_receipt"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  },
  "additionalProperties": true
}
