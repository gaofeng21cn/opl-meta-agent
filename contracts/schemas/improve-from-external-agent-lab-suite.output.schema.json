{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-meta-agent/actions/improve-from-external-agent-lab-suite.output.schema.json",
  "title": "Improve From External Agent Lab Suite Output",
  "description": "OMA judgment over an explicit OPL Foundry Lab result. OMA may emit a capability candidate and developer patch work order, but not a suite result, owner receipt, or typed-blocker body.",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "status",
    "product_id",
    "target_agent",
    "source_agent_lab_result_ref",
    "candidate_refs",
    "agent_building_judgment",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_meta_agent_external_suite_judgment"
    },
    "version": {
      "const": "opl-meta-agent.external-suite-judgment.v1"
    },
    "status": {
      "enum": [
        "no_source_patch_required",
        "completed_with_quality_debt",
        "developer_patch_work_order_ready_for_opl_foundry_lab"
      ]
    },
    "product_id": {
      "const": "opl-meta-agent"
    },
    "target_agent": {
      "type": "object",
      "required": [
        "domain_id"
      ],
      "additionalProperties": true
    },
    "source_agent_lab_result_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "foundry_lab_execution_receipt_ref": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "candidate_refs": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "missing_required_fields": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "semantic_requests": {
      "type": "object",
      "required": [
        "developer_patch_work_order",
        "physical_materialization_owner",
        "materialization_surface",
        "oma_writes_request_files",
        "requested_file_name",
        "execution_surface"
      ],
      "properties": {
        "developer_patch_work_order": {
          "type": "object"
        },
        "physical_materialization_owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "materialization_surface": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "oma_writes_request_files": {
          "const": false
        },
        "requested_file_name": {
          "const": "developer-patch-work-order.json"
        },
        "execution_surface": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "agent_building_judgment": {
      "type": "object",
      "required": ["target_capability_improvement_candidate"],
      "additionalProperties": true
    },
    "authority_boundary": {
      "$ref": "#/$defs/authorityBoundary"
    }
  },
  "oneOf": [
    {
      "properties": {
        "status": {
          "const": "no_source_patch_required"
        }
      },
      "required": [
        "foundry_lab_execution_receipt_ref"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "missing_required_fields"
            ]
          },
          { "required": ["semantic_requests"] }
        ]
      }
    },
    {
      "properties": {
        "status": {
          "const": "completed_with_quality_debt"
        },
        "authority_boundary": {
          "type": "object",
          "required": [
            "quality_debt_blocks_stage_transition",
            "quality_debt_blocks_delivery_patch_or_promotion_claims",
            "executable_work_order_materialized"
          ],
          "properties": {
            "quality_debt_blocks_stage_transition": {
              "const": false
            },
            "quality_debt_blocks_delivery_patch_or_promotion_claims": {
              "const": true
            },
            "executable_work_order_materialized": {
              "const": false
            }
          }
        }
      },
      "required": [
        "missing_required_fields"
      ],
      "not": { "required": ["semantic_requests"] }
    },
    {
      "properties": {
        "status": {
          "const": "developer_patch_work_order_ready_for_opl_foundry_lab"
        },
        "semantic_requests": {
          "required": ["developer_patch_work_order"]
        }
      },
      "required": [
        "foundry_lab_execution_receipt_ref",
        "agent_building_judgment",
        "semantic_requests"
      ],
      "not": {
        "required": [
          "missing_required_fields"
        ]
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "authorityBoundary": {
      "type": "object",
      "required": [
        "can_write_target_domain_truth",
        "can_write_target_domain_memory_body",
        "can_mutate_target_domain_artifact_body",
        "can_authorize_target_domain_quality_or_export",
        "can_promote_default_agent_without_gate"
      ],
      "properties": {
        "can_write_target_domain_truth": {
          "const": false
        },
        "can_write_target_domain_memory_body": {
          "const": false
        },
        "can_mutate_target_domain_artifact_body": {
          "const": false
        },
        "can_authorize_target_domain_quality_or_export": {
          "const": false
        },
        "can_promote_default_agent_without_gate": {
          "const": false
        },
        "oma_can_execute_agent_lab_suite": {
          "const": false
        },
        "oma_can_write_owner_receipt_body": {
          "const": false
        },
        "oma_can_write_typed_blocker_body": {
          "const": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
