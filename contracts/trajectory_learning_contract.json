{
  "surface_kind": "opl_meta_agent_trajectory_learning_contract",
  "schema_version": 1,
  "domain_id": "opl-meta-agent",
  "owner": "opl-meta-agent",
  "source_disposition": "clean_room_pattern_source",
  "source_project_ref": "https://github.com/skillnerds/xskill",
  "contract_status": "ready_for_agent_lab_consumption_refs_only",
  "role": "trajectory_atom_candidate_and_proposal_contract_not_runtime_owner",
  "absorbed_pattern_refs": [
    "xskill-pattern:trajectory-to-single-intent-atom",
    "xskill-pattern:atom-to-candidate-buffer",
    "xskill-pattern:candidate-buffer-to-skill-or-policy-proposal",
    "xskill-pattern:per-skill-versioned-canary-evidence",
    "xskill-pattern:team-redaction-before-shared-learning"
  ],
  "forbidden_imports": [
    "xskill-daemon-runtime",
    "xskill-team-server",
    "xskill-user-scope-skill-installer",
    "xskill-generic-scheduler",
    "xskill-canary-as-owner-verdict"
  ],
  "semantic_pack_refs": [
    "agent/knowledge/trajectory-learning-policy.md",
    "agent/prompts/trajectory-learning-intake.md",
    "agent/skills/trajectory-learning-intake.md",
    "agent/quality_gates/trajectory-learning-proposal.md",
    "agent/stages/trajectory-learning-intake.md"
  ],
  "learning_flow": [
    {
      "step_id": "redacted_trajectory_ref_intake",
      "input_refs": [
        "trajectory_ref",
        "source_agent_ref",
        "workspace_ref"
      ],
      "output_refs": [
        "redacted_trajectory_ref",
        "redaction_proof_ref",
        "source_provenance_ref"
      ],
      "fail_closed_blocker_refs": [
        "blocker:missing_redaction_proof_ref",
        "blocker:missing_source_provenance_ref"
      ]
    },
    {
      "step_id": "single_intent_atomization",
      "input_refs": [
        "redacted_trajectory_ref"
      ],
      "output_refs": [
        "trajectory_atom_refs",
        "atom_boundary_rationale_refs"
      ],
      "fail_closed_blocker_refs": [
        "blocker:ambiguous_atom_boundary",
        "blocker:atom_contains_multiple_user_intents"
      ]
    },
    {
      "step_id": "candidate_buffer_accumulation",
      "input_refs": [
        "trajectory_atom_refs",
        "existing_skill_prompt_stage_policy_refs"
      ],
      "output_refs": [
        "candidate_buffer_ref",
        "candidate_weight_evidence_refs"
      ],
      "fail_closed_blocker_refs": [
        "blocker:single_atom_attempted_direct_promotion",
        "blocker:candidate_weight_lacks_evidence"
      ]
    },
    {
      "step_id": "proposal_materialization",
      "input_refs": [
        "candidate_buffer_ref",
        "candidate_weight_evidence_refs",
        "independent_ai_review_ref"
      ],
      "output_refs": [
        "skill_policy_candidate_ref",
        "prompt_policy_candidate_ref",
        "stage_policy_candidate_ref",
        "mechanism_patch_proposal_ref"
      ],
      "fail_closed_blocker_refs": [
        "blocker:missing_independent_ai_review_ref",
        "blocker:proposal_would_write_target_truth_or_memory"
      ]
    },
    {
      "step_id": "agent_lab_promotion_gate",
      "input_refs": [
        "mechanism_patch_proposal_ref",
        "ux_signal_ref",
        "canary_evidence_ref"
      ],
      "output_refs": [
        "agent_lab_promotion_gate_ref",
        "owner_review_receipt_or_typed_blocker_ref"
      ],
      "fail_closed_blocker_refs": [
        "blocker:ux_score_claimed_as_quality_verdict",
        "blocker:missing_agent_lab_promotion_gate_ref",
        "blocker:missing_owner_review_receipt_or_typed_blocker_ref"
      ]
    }
  ],
  "candidate_surfaces": [
    {
      "surface_id": "skill_policy_candidate",
      "candidate_ref_kind": "domain_skill_policy_candidate_ref",
      "editable_surface": "agent/skills",
      "promotion_authority": "OPL Agent Lab plus opl-meta-agent owner review",
      "can_replace_skill_without_gate": false
    },
    {
      "surface_id": "prompt_policy_candidate",
      "candidate_ref_kind": "domain_prompt_policy_candidate_ref",
      "editable_surface": "agent/prompts",
      "promotion_authority": "OPL Agent Lab plus opl-meta-agent owner review",
      "can_replace_prompt_without_gate": false
    },
    {
      "surface_id": "stage_policy_candidate",
      "candidate_ref_kind": "domain_stage_policy_candidate_ref",
      "editable_surface": "agent/stages",
      "promotion_authority": "OPL Agent Lab plus opl-meta-agent owner review",
      "can_replace_stage_policy_without_gate": false
    }
  ],
  "evidence_signal_policy": {
    "ux_score_role": "evidence_signal_only",
    "canary_role": "comparative_evidence_only",
    "canary_or_ux_can_authorize_quality_verdict": false,
    "canary_or_ux_can_promote_default_agent": false,
    "required_reviewer_ref": "independent-ai-review-ref:trajectory-learning",
    "required_gate_ref": "agent-lab-promotion-gate-ref:trajectory-learning"
  },
  "team_learning_boundary": {
    "redaction_required_before_shared_learning": true,
    "client_is_authoritative_for_skill_state": false,
    "server_or_domain_repo_can_write_user_scope_skill_install": false,
    "shared_learning_outputs_are_refs_only": true,
    "allowed_shared_payload_refs": [
      "redacted_trajectory_ref",
      "atom_summary_ref",
      "candidate_buffer_ref",
      "proposal_ref",
      "typed_blocker_ref"
    ],
    "forbidden_shared_payload_refs": [
      "secret_value",
      "private_key",
      "raw_token",
      "unredacted_trajectory_body"
    ]
  },
  "required_receipt_refs": [
    "redaction-proof-ref",
    "trajectory-atomization-receipt-ref",
    "candidate-buffer-receipt-ref",
    "ux-signal-ref-not-quality-verdict",
    "independent-ai-review-ref",
    "agent-lab-promotion-gate-ref",
    "no-forbidden-write-proof-ref:trajectory-learning"
  ],
  "human_doc_refs": [
    "docs/status.md",
    "docs/architecture.md",
    "docs/decisions.md",
    "docs/invariants.md"
  ],
  "verified_by_refs": [
    "tests/contracts-domain-pack.test.ts"
  ],
  "authority_boundary": {
    "refs_only": true,
    "not_generic_runtime_owner": true,
    "opl_owns_generic_ingest_and_sync_runtime": true,
    "agent_lab_owns_promotion_gate": true,
    "oma_outputs_are_proposals_only": true,
    "can_run_trajectory_daemon": false,
    "can_own_generic_scheduler": false,
    "can_own_generic_queue_or_attempt_ledger": false,
    "can_install_user_scope_skills": false,
    "can_write_target_domain_truth": false,
    "can_write_target_domain_memory_body": false,
    "can_mutate_target_domain_artifact_body": false,
    "can_authorize_target_domain_quality_or_export": false,
    "can_claim_ux_score_as_quality_verdict": false,
    "can_promote_default_agent_without_gate": false
  }
}
