  "seed_patterns": [
    {
      "pattern_id": "case_grounded_expert_decision_workflow.v1",
      "pattern_ref": "expert-workflow-pattern:oma/case-grounded-expert-decision-workflow.v1",
      "display_name": "Case-Grounded Expert Decision Workflow",
      "replaces_names": [
        "clinical_decision_support_template",
        "evidence_grounded_decision_agent_template"
      ],
      "primary_use": "Complex case or material grounded expert decision support where the target owner keeps final authority.",
      "authority_tier": "A",
      "source_refs": [
        "doi:10.1038/s41591-026-04494-4"
      ],
      "applicable_constraints": [
        "case_or_material_grounded_expert_decision",
        "human_owner_retains_final_authority"
      ],
      "non_transferable_constraints": [
        "source_runtime_topology",
        "private_case_data",
        "clinical_or_professional_verdict"
      ],
      "transferable_workflow_steps": [
        {
          "step_id": "case_material_intake",
          "expert_question": "What materials define the case, and what is the decision the owner is actually asking for?",
          "stage_archetype": "material_or_case_intake",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1038/s41591-026-04494-4#workflow/case_material_intake"]
        },
        {
          "step_id": "structured_case_extraction",
          "expert_question": "Which variables, constraints, chronology, and missing data points matter for this decision?",
          "stage_archetype": "structured_extraction",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1038/s41591-026-04494-4#workflow/structured_case_extraction"]
        },
        {
          "step_id": "decision_problem_framing",
          "expert_question": "What decision options, risks, and human gate points are in scope?",
          "stage_archetype": "mode_routing",
          "provenance_kind": "internal_synthesis",
          "source_anchor_refs": ["doi:10.1038/s41591-026-04494-4#criteria/decision_problem_framing"]
        },
        {
          "step_id": "evidence_contextualization",
          "expert_question": "Which references apply to this case, and where do they not apply?",
          "stage_archetype": "evidence_and_tool_execution",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1038/s41591-026-04494-4#workflow/evidence_contextualization"]
        },
        {
          "step_id": "case_grounded_synthesis",
          "expert_question": "How do the case facts and applicable evidence change the reasoning?",
          "stage_archetype": "synthesis",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1038/s41591-026-04494-4#workflow/case_grounded_synthesis"]
        },
        {
          "step_id": "uncertainty_and_blocker_review",
          "expert_question": "Which conclusions are unsupported, unsafe, or require more owner input?",
          "stage_archetype": "unsupported_evidence_blocker",
          "provenance_kind": "internal_synthesis",
          "source_anchor_refs": ["doi:10.1038/s41591-026-04494-4#criteria/uncertainty_and_blocker_review"]
        },
        {
          "step_id": "independent_review_or_human_gate",
          "expert_question": "Would an independent reviewer or domain owner accept the reasoning trace?",
          "stage_archetype": "independent_review_or_human_gate",
          "provenance_kind": "internal_synthesis",
          "source_anchor_refs": ["doi:10.1038/s41591-026-04494-4#criteria/independent_review_or_human_gate"]
        }
      ],
      "suggested_oma_inputs": {
        "reference_design_pattern_packet_ref": "expert-workflow-pattern:oma/case-grounded-expert-decision-workflow.v1",
        "reference_design_pattern_note": "Use case-grounded expert decision workflow: intake, structured extraction, decision framing, evidence contextualization, synthesis, unsupported-evidence blocker, and human gate."
      },
      "quality_gate_refs": [
        "quality-gate-ref:decision-support-forbidden-claims",
        "quality-gate-ref:evidence-trace-required",
        "quality-gate-ref:human-owner-final-authority"
      ],
      "forbidden_claims": [
        "domain_ready",
        "clinical_or_professional_verdict_final",
        "owner_accepted",
        "production_ready"
      ]
    },
    {
      "pattern_id": "guideline_to_decision_workflow.v1",
      "pattern_ref": "expert-workflow-pattern:oma/guideline-to-decision-workflow.v1",
      "display_name": "Guideline-to-Decision Expert Workflow",
      "primary_use": "Translate guideline or policy evidence into an owner-gated recommendation artifact.",
      "authority_tier": "S",
      "source_refs": [
        "doi:10.1136/bmj.i2016",
        "source-ref:agree-ii-2017"
      ],
      "applicable_constraints": [
        "guideline_or_policy_evidence_to_owner_decision",
        "decision_context_and_scope_are_explicit"
      ],
      "non_transferable_constraints": [
        "guideline_recommendation_as_target_owner_verdict",
        "stale_guideline_version",
        "source_context_without_target_applicability_review"
      ],
      "transferable_workflow_steps": [
        {
          "step_id": "decision_context_intake",
          "expert_question": "What decision, population, setting, stakeholder, and constraints are being considered?",
          "stage_archetype": "decision_context_intake",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1136/bmj.i2016#workflow/decision_context_intake"]
        },
        {
          "step_id": "guideline_scope_fit",
          "expert_question": "Does this guideline actually apply to the target context?",
          "stage_archetype": "reference_scope_appraisal",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1136/bmj.i2016#workflow/guideline_scope_fit"]
        },
        {
          "step_id": "evidence_to_decision_factor_review",
          "expert_question": "What is known about benefits, harms, certainty, resources, values, feasibility, and equity?",
          "stage_archetype": "evidence_factor_review",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1136/bmj.i2016#workflow/evidence_to_decision_factor_review"]
        },
        {
          "step_id": "recommendation_shape_design",
          "expert_question": "What recommendation strength, caveats, and owner choices follow from the factors?",
          "stage_archetype": "recommendation_synthesis",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["doi:10.1136/bmj.i2016#workflow/recommendation_shape_design"]
        },
        {
          "step_id": "applicability_and_update_check",
          "expert_question": "What version, freshness, local protocol, or exception should block or qualify the output?",
          "stage_archetype": "freshness_and_scope_gate",
          "provenance_kind": "internal_synthesis",
          "source_anchor_refs": [
            "doi:10.1136/bmj.i2016#criteria/applicability_and_update_check",
            "source-ref:agree-ii-2017#evaluation/applicability"
          ]
        }
      ],
      "suggested_oma_inputs": {
        "reference_design_pattern_packet_ref": "expert-workflow-pattern:oma/guideline-to-decision-workflow.v1",
        "reference_design_pattern_note": "Use guideline-to-decision workflow: context, scope fit, evidence-to-decision factors, recommendation shape, applicability and update gate."
      },
      "quality_gate_refs": [
        "quality-gate-ref:guideline-version-and-scope",
        "quality-gate-ref:benefit-harm-certainty-trace",
        "quality-gate-ref:owner-context-required"
      ],
      "forbidden_claims": [
        "guideline_is_target_truth",
        "recommendation_final_without_owner_gate"
      ]
    },
    {
      "pattern_id": "systematic_evidence_synthesis_workflow.v1",
      "pattern_ref": "expert-workflow-pattern:oma/systematic-evidence-synthesis-workflow.v1",
      "display_name": "Systematic Evidence Synthesis Expert Workflow",
      "primary_use": "Evidence review, systematic review, scoping review, or literature evidence package.",
      "authority_tier": "S",
      "source_refs": [
        "source-ref:cochrane-handbook-v6.5-2024",
        "doi:10.1136/bmj.n71"
      ],
      "applicable_constraints": [
        "systematic_evidence_question_with_reproducible_search_and_selection",
        "bias_and_certainty_must_be_explicit"
      ],
      "non_transferable_constraints": [
        "reporting_checklist_as_workflow_sequence",
        "unstated_screening_or_exclusion_logic",
        "certainty_claim_without_evidence_assessment"
      ],
      "transferable_workflow_steps": [
        {
          "step_id": "review_question_feasibility",
          "expert_question": "Is the review question answerable, useful, and scoped tightly enough?",
          "stage_archetype": "question_feasibility",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["source-ref:cochrane-handbook-v6.5-2024#workflow/review_question_feasibility"]
        },
        {
          "step_id": "protocol_and_search_strategy",
          "expert_question": "What sources, terms, dates, languages, and inclusion logic define the search?",
          "stage_archetype": "search_protocol_design",
          "provenance_kind": "source_derived",
          "source_anchor_refs": [
            "source-ref:cochrane-handbook-v6.5-2024#workflow/protocol_and_search_strategy",
            "doi:10.1136/bmj.n71#quality/protocol_and_search_reporting"
          ]
        },
        {
          "step_id": "screening_decision_process",
          "expert_question": "Which records should be included, excluded, or escalated for adjudication?",
          "stage_archetype": "screening_and_adjudication",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["source-ref:cochrane-handbook-v6.5-2024#workflow/screening_decision_process"]
        },
        {
          "step_id": "data_extraction_and_normalization",
          "expert_question": "What facts must be extracted consistently enough to support synthesis?",
          "stage_archetype": "structured_extraction",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["source-ref:cochrane-handbook-v6.5-2024#workflow/data_extraction_and_normalization"]
        },
        {
          "step_id": "bias_and_certainty_assessment",
          "expert_question": "How reliable is the evidence, and what downgrades or limitations matter?",
          "stage_archetype": "risk_of_bias_and_certainty",
          "provenance_kind": "source_derived",
          "source_anchor_refs": ["source-ref:cochrane-handbook-v6.5-2024#workflow/bias_and_certainty_assessment"]
        },
        {
          "step_id": "synthesis_and_gap_statement",
          "expert_question": "What can be concluded, what conflicts remain, and what cannot be claimed?",
          "stage_archetype": "evidence_synthesis",
          "provenance_kind": "source_derived",
          "source_anchor_refs": [
            "source-ref:cochrane-handbook-v6.5-2024#workflow/synthesis_and_gap_statement",
            "doi:10.1136/bmj.n71#quality/synthesis_reporting"
          ]
        }
      ],
      "suggested_oma_inputs": {
        "reference_design_pattern_packet_ref": "expert-workflow-pattern:oma/systematic-evidence-synthesis-workflow.v1",
        "reference_design_pattern_note": "Use systematic evidence synthesis workflow: feasibility, protocol/search, screening, extraction, bias/certainty, synthesis and gap statement."
      },
      "quality_gate_refs": [
        "quality-gate-ref:search-strategy-reproducibility",
        "quality-gate-ref:screening-exclusion-trace",
        "quality-gate-ref:certainty-and-bias-required"
      ],
      "forbidden_claims": [
        "complete_evidence_capture_without_search_trace",
        "certainty_claim_without_bias_assessment"
      ]
    },
    {
