    {
      "pattern_id": "clinical_ai_evaluation_workflow.v1",
      "pattern_ref": "expert-workflow-pattern:oma/clinical-ai-evaluation-workflow.v1",
      "display_name": "Clinical AI Evaluation Expert Workflow",
      "primary_use": "Evaluate a clinical AI workflow, early deployment, or trial-readiness package.",
      "authority_tier": "S",
      "source_refs": [
        "doi:10.1038/s41591-022-01772-9",
        "doi:10.1038/s41591-020-1034-x",
        "doi:10.1038/s41591-020-1037-7"
