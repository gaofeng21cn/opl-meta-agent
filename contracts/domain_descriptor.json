{
  "surface_kind": "domain_agent_descriptor",
  "schema_version": 1,
  "agent_id": "oma",
  "package_id": "oma",
  "domain_id": "agent_engineering",
  "carrier_slug": "opl-meta-agent",
  "domain_label": "OPL Meta Agent",
  "agent_role": "foundry_semantic_provider",
  "delivery_domain": "agent_engineering",
  "purpose": "Design, evaluate semantically, diagnose, and evolve OPL-compatible Agents without owning execution or release state.",
  "public_action_ids": ["engineer-agent"],
  "internal_provider_operations": ["design", "diagnose"],
  "standard_contract_refs": {
    "action_catalog": "contracts/action_catalog.json",
    "foundry_provider": "contracts/foundry_provider.json",
    "stage_manifest": "agent/stages/manifest.json",
    "pack_compiler_input": "contracts/pack_compiler_input.json",
    "generated_surface_handoff": "contracts/generated_surface_handoff.json"
  },
  "standard_agent_interface": {
    "version": "opl_standard_agent_interface.v1",
    "stage_catalog": {
      "source_kind": "agent_repo_relative_json",
      "relative_path": "agent/stages/manifest.json",
      "items_pointer": "/stages",
      "field_map": {
        "stage_id": "stage_id",
        "display_name": "title",
        "display_names": "display_names"
      }
    },
    "workspace_binding": {
      "locator_surface_kind": "opl_foundry_design_request",
      "default_profile_id": "one_off",
      "workspace_kind": "foundry_agent_engineering_workspace",
      "project_kind": "target_agent_project",
      "project_collection_label": "target_agents",
      "default_workspace_id": "oma-foundry",
      "default_project_id": "agent-engineering",
      "required_locator_fields": [],
      "optional_locator_fields": ["workspace_root", "profile_ref"]
    },
    "runtime": {
      "runtime_domain_id": "agent_engineering",
      "registration_ref": "contracts/opl_domain_manifest_registration.json"
    },
    "progress": {
      "deliverable_delta_aliases": ["foundry_run_delta"],
      "platform_delta_aliases": ["foundry_platform_delta"]
    },
    "routing": {
      "explicit_aliases": ["oma", "opl-meta-agent", "agent-engineering"],
      "workstream_ids": ["agent_engineering"],
      "intent_signals": ["agent_creation", "agent_takeover", "agent_improvement"],
      "ambiguity_policy": "require_explicit_agent_engineering_intent"
    }
  },
  "authority_boundary": {
    "oma_can_write_target_domain_truth": false,
    "oma_can_materialize_candidate_bytes": false,
    "oma_can_execute_or_judge_evaluation": false,
    "oma_can_create_versions_or_change_activation": false,
    "opl_can_write_target_domain_truth": false,
    "provider_completion_is_qualification": false
  }
}
