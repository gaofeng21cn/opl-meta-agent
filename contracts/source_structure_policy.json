{
  "surface_kind": "opl_family_source_structure_policy",
  "version": "source-structure-policy.v1",
  "owner": "opl-meta-agent",
  "target_domain_id": "opl-meta-agent",
  "purpose": "family_level_source_structure_lane",
  "state": "active_machine_policy",
  "machine_boundary": "scripts/check-source-structure.ts consumes this policy; scripts/sync-authority-functions.ts consumes the authority-functions source contract.",
  "scan_scope": {
    "tracked_only": true,
    "path_prefixes": [
      "agent/",
      "contracts/",
      "runtime/",
      "scripts/",
      "tests/"
    ],
    "extensions": [
      ".json",
      ".md",
      ".sh",
      ".ts"
    ],
    "excluded_paths": []
  },
  "lanes": {
    "advisory": {
      "budget_lines": 1000,
      "fail_on_over_budget": false,
      "command_ref": "npm run source-structure"
    },
    "strict": {
      "budget_lines": 1000,
      "fail_on_over_budget": true,
      "command_ref": "npm run source-structure:strict"
    }
  },
  "compatibility_aliases": [],
  "generated_aggregate_exemptions": [
    {
      "aggregate_ref": "runtime/authority_functions/meta-agent-authority-functions.json",
      "source_contract_ref": "runtime/authority_functions/meta-agent-authority-functions.source.json",
      "leaf_index_ref": "runtime/authority_functions/meta-agent-authority-functions.leaf-index.json",
      "bundle_manifest_ref": "runtime/authority_functions/meta-agent-authority-functions.bundle-manifest.json",
      "check_command": "npm run authority-functions:check",
      "line_budget_exemption": "generated_authority_manifest_reconstructed_from_split_source",
      "consumer_surface_must_remain": true,
      "generated_consumer_surface_must_be_do_not_edit": true
    }
  ],
  "script_to_pack_receipt_guard": {
    "guard_id": "oma.source_structure.script_to_pack_receipt_drift_guard.v1",
    "state": "active_executable_guard",
    "command_ref": "npm run source-structure",
    "json_readback_command_ref": "npm run source-structure:json",
    "cleanup_readback_command_ref": "npm run script-to-pack:readback",
    "full_cleanup_readback_command_ref": "npm run script-to-pack:readback:full",
    "receipt_ref": "contracts/script_to_pack_gate_receipt.json",
    "authority_functions_ref": "runtime/authority_functions/meta-agent-authority-functions.json",
    "source_receipt_path": "source_purity_scan_receipt",
    "script_morphology_path": "script_morphology_policy",
    "cleanup_readback_output_ref": "source-structure-readback.script_to_pack_receipt_guard.cleanup_readback",
    "direct_readback_compact_summary_output_ref": "script-to-pack-readback.compact_cleanup_summary",
    "direct_readback_full_detail_output_ref": "script-to-pack-readback-full.cleanup_candidates",
    "compact_cleanup_summary_id": "oma.script_to_pack_retirement_cleanup.compact_summary.v1",
    "cleanup_readback_surface_kind": "oma_script_to_pack_retirement_cleanup_compact_readback",
    "full_cleanup_readback_surface_kind": "oma_script_to_pack_retirement_cleanup_readback",
    "cleanup_readback_compact_summary_role": "direct_readback_short_form_not_second_script_inventory",
    "repo_native_retention_overrides": [
      {
        "gate_id": "source_structure_and_authority_manifest_maintenance_helpers",
        "retention_state": "retained_current_repo_native_surface",
        "retention_reason": "current repo-native source-structure and authority-functions aggregate sync maintenance surface with active package, verify, and contract/readback callers; it remains a verification and cache-boundary surface, not a runtime owner or production readiness claim",
        "retention_evidence_refs": [
          "contracts/source_structure_policy.json",
          "package.json#scripts.source-structure",
          "package.json#scripts.script-to-pack:readback",
          "package.json#scripts.authority-functions:check",
          "scripts/verify.sh#structure",
          "tests/source-structure-lane.test.ts#source-structure-and-authority-manifest-retention",
          "tests/source-purity/script-morphology.test-case.ts#source-structure-maintenance-gate"
        ],
        "no_resurrection_policy": {
          "policy_id": "oma.repo_native_source_structure_helpers.no_resurrection.v1",
          "state": "active_machine_policy",
          "retained_only_while_active_repo_native_callers_exist": true,
          "must_not_restore_as_generic_runtime_owner": true,
          "must_not_restore_as_generated_interface_owner": true,
          "must_not_restore_as_domain_truth_writer": true,
          "must_not_claim_line_budget_default_hard_gate": true,
          "future_retirement_requires_existing_gate_required_before_retire_or_absorb": true
        }
      },
      {
        "gate_id": "repo_shell_verification_wrappers",
        "retention_state": "retained_current_repo_native_surface",
        "retention_reason": "current repo-native verification, hygiene, and external temp/cache-boundary shell surface with active package and verify callers; it remains a local verification wrapper set, not a runtime owner, scheduler, queue, target truth, quality verdict, or production readiness surface",
        "retention_evidence_refs": [
          "contracts/source_structure_policy.json",
          "package.json#scripts.verify",
          "package.json#scripts.test:smoke",
          "package.json#scripts.repo:hygiene",
          "package.json#scripts.typecheck",
          "scripts/verify.sh",
          "scripts/run-with-repo-temp-env.sh",
          "scripts/repo-hygiene.sh",
          "tests/source-structure-lane.test.ts#repo-shell-verification-retention",
          "tests/contracts-repo-hygiene.test.ts"
        ],
        "no_resurrection_policy": {
          "policy_id": "oma.repo_shell_verification_wrappers.no_resurrection.v1",
          "state": "active_machine_policy",
          "retained_only_while_active_repo_native_callers_exist": true,
          "must_not_restore_as_generic_cli_product_wrapper": true,
          "must_not_restore_as_generic_runtime_owner": true,
          "must_not_restore_as_scheduler_or_daemon": true,
          "must_not_restore_as_queue_or_attempt_ledger": true,
          "must_not_restore_as_target_truth_or_quality_writer": true,
          "must_not_claim_line_budget_default_hard_gate": true,
          "future_retirement_requires_existing_gate_required_before_retire_or_absorb": true
        }
      }
    ],
    "cleanup_readback_required_fields": [
      "script_ref",
      "gate_id",
      "current_role",
      "classes",
      "active_caller_refs",
      "missing_evidence",
      "retained_current_rows",
      "retained_current_authority_functions",
      "retained_current_repo_native_surface_count",
      "owner_delta_route",
      "typed_blocker_ref_shape",
      "can_apply_cleanup"
    ],
    "validated_summary_fields": [
      "source_purity_scan_status",
      "active_script_caller_scan_status",
      "active_caller_scan_policy_id",
      "source_ref_integrity_guard_id",
      "source_ref_integrity_status",
      "scanned_script_count",
      "gated_script_count",
      "orphan_script_count",
      "script_gate_count",
      "scanned_script_refs",
      "gated_script_refs",
      "active_caller_scan_self_guard_refs"
    ],
    "fail_closed_conditions": [
      "receipt_contract_missing",
      "authority_functions_aggregate_missing",
      "source_purity_scan_receipt_drift",
      "script_morphology_policy_drift",
      "tracked_script_not_in_receipt",
      "receipt_scanned_script_not_tracked",
      "gated_script_refs_drift",
      "orphan_script_count_nonzero",
      "receipt_claims_retirement_or_readiness",
      "cleanup_readback_missing_candidate",
      "cleanup_readback_retained_current_drift",
      "cleanup_readback_claims_cleanup_apply",
      "compact_cleanup_summary_drift",
      "compact_cleanup_summary_claims_cleanup_or_readiness"
    ],
    "false_authority_boundary": {
      "guard_can_authorize_script_retirement": false,
      "guard_can_claim_opl_primitive_parity": false,
      "guard_can_claim_no_active_caller": false,
      "guard_can_write_target_domain_truth": false,
      "guard_can_write_target_owner_receipt_body": false,
      "guard_can_claim_app_or_registry_readiness": false,
      "guard_can_claim_generated_hosted_readiness": false,
      "guard_can_claim_target_agent_ready": false,
      "guard_can_claim_domain_ready": false,
      "guard_can_claim_production_ready": false
    }
  },
  "authority_boundary": {
    "domain_truth_owner": "opl-meta-agent",
    "source_structure_lane_owner": "opl-meta-agent",
    "generated_interface_owner": "one-person-lab",
    "can_write_target_domain_truth": false,
    "can_write_target_owner_receipt_body": false,
    "can_claim_quality_or_export": false
  }
}
