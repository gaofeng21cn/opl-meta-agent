{
  "surface_kind": "standard_foundry_policy_consumer",
  "version": "standard-foundry-policy-consumer.v1",
  "owner": "opl-meta-agent",
  "purpose": "Bind OMA Foundry authoring deltas to the canonical OPL Foundry policy consumer.",
  "state": "active_contract",
  "machine_boundary": "OPL canonical contracts own shared Foundry policy bodies. OMA stores only the release pin, canonical refs, and agent-building deltas consumed by stage decomposition.",
  "canonical_policy_export": "opl-framework-shared/foundry-agent-series-policy",
  "canonical_series_contract_ref": "contracts/opl-framework/foundry-agent-series-contract.json",
  "canonical_skeleton_contract_ref": "contracts/opl-framework/standard-domain-agent-skeleton-contract.json",
  "active_policy_consumer_refs": [
    "scripts/lib/stage-decomposition-pack-draft/shared.ts"
  ],
  "shared_policy_release": {
    "policy_release_contract_ref": "contracts/opl-framework/foundry-agent-series-policy-release.json",
    "policy_bundle_fingerprint": "sha256:503f515e8fa08b3f81ce28cac461368c609d4565de239c9f95c3f910cb758ed5",
    "fingerprint_algorithm": "sha256:stable-json",
    "domain_contract_policy_release_pin_required": true,
    "domain_adapter_must_not_copy_policy_body_as_authority": true,
    "consumer_alignment_check": "foundry:policy-release"
  },
  "domain_policy_delta": {
    "series_design_profile": {
      "stage_pack_section_additions": [
        "artifact_morphology"
      ],
      "artifact_morphology_policy": {
        "surface_kind": "target_domain_artifact_morphology_policy",
        "version": "artifact-morphology-policy.v1",
        "required_for_new_target_agent_baseline": true,
        "required_contract_ref": "contracts/artifact_morphology_contract.json",
        "required_closeout_field": "stage_decomposition_pack_draft.artifact_morphology_contract",
        "required_stage_contract_field": "stage_contract.artifact_morphology_contract",
        "required_stage_refs": [
          "artifact_morphology_ref",
          "artifact_native_source_format_ref",
          "artifact_shard_unit_ref",
          "target_extent_contract_ref",
          "asset_custody_ref"
        ],
        "must_cover": [
          "native_source_format",
          "creative_source_vs_assembled_or_export_ref",
          "sharding_strategy",
          "owner_or_source_declared_extent",
          "asset_file_path_custody",
          "thin_assembler_or_helper_boundary",
          "realistic_target_task_review"
        ],
        "fail_closed_conditions": [
          "creative artifact body is stored primarily in generator code",
          "book-length or large artifact lacks shard unit policy",
          "owner/source declared extent is silently reduced",
          "final generated asset has no project-local exposed path",
          "baseline reviewer evidence only cites scaffold, generated interface, or scorecard refs"
        ],
        "authority_boundary": {
          "oma_can_write_target_artifact_body": false,
          "opl_can_infer_artifact_body_shape": false,
          "target_domain_owner_must_accept_artifact_shape": true
        }
      }
    },
    "stage_progress_delta_policy": {
      "authority_boundary": {
        "oma_retains_agent_building_semantics": true
      }
    },
    "typed_blocker_lineage_policy": {
      "authority_boundary": {
        "oma_retains_typed_blocker_authority": true
      }
    }
  },
  "authority_boundary": {
    "can_write_target_domain_truth": false,
    "can_read_target_domain_body": false,
    "can_authorize_target_quality_or_export": false,
    "can_promote_default_agent": false,
    "can_replace_opl_framework_or_agent_lab": false
  }
}
