{
  "surface_kind": "oma_self_evolution_closeout_contract",
  "version": "oma-self-evolution-closeout.v1",
  "owner": "opl-meta-agent",
  "purpose": "Prepare a same-identity Agent Lab re-evaluation and consume a target-owner terminal answer without owning target truth or OPL work-order lifecycle.",
  "target_policy_locator": "contracts/agent_lab_self_evolution_policy.json",
  "prepare_re_evaluation": {
    "required_inputs": [
      "source_suite",
      "source_execution_receipt",
      "target_agent_declarative_policy"
    ],
    "identity_must_remain_equal": [
      "suite_id",
      "tasks[].task_id",
      "evaluation_target_agent",
      "feedback_self_evolution_trigger.target_agent_id"
    ],
    "legacy_domain_suite_target_binding": "feedback_self_evolution_trigger.target_agent_id must equal source_execution_receipt.target_agent.domain_id",
    "domain_quality_fields_must_remain_equal": [
      "tasks[].scorecard"
    ],
    "allowed_projection_changes": [
      "tasks[].stage_completion_policy",
      "tasks[].improvement_candidate.allowed_change_scope",
      "tasks[].promotion_gate",
      "self_evolution_re_evaluation_context"
    ],
    "required_mechanism_risk_tier": "high_risk",
    "automatic_mechanism_promotion_ready": false
  },
  "owner_closeout_replay_draft": {
    "role": "refs-only replay of an absorbed OPL receipt with a fresh suite result",
    "is_opl_execution_receipt": false,
    "writes_target_owner_answer": false,
    "target_owner_command_owner": "med-autoscience"
  },
  "terminal_outcome_mapping": {
    "domain_receipt": "target_owner_accepted",
    "no_regression_evidence": "target_owner_waived",
    "typed_blocker": "target_owner_blocked"
  },
  "required_owner_response_flags": {
    "refs_only": true,
    "writes_visual_truth": false,
    "writes_artifact_body": false,
    "writes_memory_body": false,
    "authorizes_quality_or_export": false,
    "authorizes_publication_or_submission": false,
    "authorizes_domain_ready": false,
    "automatic_mechanism_promotion_ready": false
  },
  "authority_boundary": {
    "oma_can_prepare_refs_only_re_evaluation": true,
    "oma_can_consume_target_owner_answer": true,
    "oma_can_execute_agent_lab": false,
    "oma_can_manage_worktree_or_absorption": false,
    "oma_can_write_target_owner_receipt": false,
    "oma_can_change_domain_scorecard": false,
    "oma_can_authorize_publication_or_submission": false,
    "oma_can_promote_default_agent": false
  }
}
