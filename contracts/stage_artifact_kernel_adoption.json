{
  "surface_kind": "opl_stage_artifact_kernel_adoption",
  "version": "opl-stage-artifact-kernel-adoption.v1",
  "owner": "opl-meta-agent",
  "domain_id": "opl-meta-agent",
  "kernel_contract_ref": "contracts/opl-framework/stage-artifact-runtime-contract.json",
  "stage_folder_unit": [
    "Stage Folder",
    "Manifest",
    "Receipt",
    "current pointer"
  ],
  "terminal_states": [
    "success",
    "blocked",
    "skipped",
    "deferred"
  ],
  "required_ref_fields": [
    "stage_folder_contract_ref",
    "stage_json_ref",
    "attempt_json_ref",
    "manifest_ref",
    "receipt_ref",
    "current_pointer_ref",
    "canonical_artifact_ref",
    "export_ref",
    "lineage_ref",
    "retention_ref"
  ],
  "kernel_refs": {
    "physical_stage_folder_source_of_truth": true,
    "derived_index_rebuildable": true,
    "manifest_receipt_hash_required": true
  },
  "state_index_kernel_adoption": {
    "surface_kind": "opl_state_index_kernel_sqlite_sidecar_adoption",
    "version": "opl-state-index-kernel-sqlite-sidecar-adoption.v1",
    "kernel_owner": "one-person-lab",
    "index_owner": "one-person-lab",
    "index_kind": "sqlite_sidecar_index",
    "oma_role": "refs_only_index_source",
    "sidecar_index_authority": "derived_read_model_only",
    "derived_index_rebuildable": true,
    "indexed_subjects_must_be_refs_only": true,
    "allowed_index_ref_classes": [
      "candidate_package_ref",
      "agent_lab_result_ref",
      "developer_work_order_ref",
      "typed_blocker_ref",
      "mechanism_patch_proposal_ref"
    ],
    "allowed_index_payload_roles": [
      "ref",
      "status",
      "source_ref",
      "receipt_ref",
      "blocker_ref",
      "proposal_ref"
    ],
    "forbidden_index_payload_roles": [
      "target_truth_body",
      "target_runtime_state_body",
      "target_artifact_body",
      "target_memory_body",
      "target_quality_verdict_body",
      "target_export_verdict_body",
      "target_owner_receipt_body",
      "target_worktree_lifecycle_state",
      "queue_state",
      "attempt_ledger_body",
      "promotion_gate_verdict"
    ],
    "authority_boundary": {
      "oma_can_own_state_index_kernel": false,
      "oma_can_own_sqlite_sidecar_index": false,
      "oma_can_manage_queue": false,
      "oma_can_manage_attempt_ledger": false,
      "oma_can_manage_target_runtime": false,
      "oma_can_manage_target_worktree_lifecycle": false,
      "oma_can_manage_promotion_gate": false,
      "oma_can_write_target_truth": false,
      "oma_can_write_target_artifact_body": false,
      "oma_can_write_target_memory_body": false,
      "oma_can_write_target_quality_or_export_verdict": false,
      "oma_can_write_target_owner_receipt_body": false
    }
  },
  "domain_pack_binding": {
    "accepted_source_refs": [
      "agent/stages/manifest.json",
      "contracts/foundry_agent_series.json",
      "scripts/lib/stage-native-artifact-contract.ts",
      "scripts/lib/stage-decomposition-pack-draft/builder.ts",
      "scripts/lib/stage-decomposition-pack-draft/materializer.ts",
      "scripts/lib/stage-decomposition-pack-draft/shared.ts",
      "scripts/lib/stage-decomposition-pack-draft/validator.ts"
    ],
    "domain_output_roles_are_interface": true,
    "file_name_is_not_interface": true,
    "domain_truth_owner": "opl-meta-agent"
  },
  "projection_boundary": {
    "derived_projection_refs": [
      "stage_native_artifact_contract_bundle",
      "target_agent_stage_artifact_ref_templates",
      "agent_lab_work_order_refs",
      "app_workbench_artifact_drilldown"
    ],
    "file_presence_only_counts_as": "orphan_or_historical",
    "provider_completion_counts_as_progress": false,
    "derived_index_authority": "ref_template_materialization_only"
  },
  "authority_boundary": {
    "opl_can_create_domain_owner_receipt": false,
    "opl_can_write_domain_truth": false,
    "opl_can_write_memory_body": false,
    "opl_can_mutate_domain_artifact_body": false,
    "opl_can_authorize_quality_or_export": false
  },
  "domain_authority_retained": [
    "agent_building_semantics",
    "work_order_semantic_request_authoring",
    "mechanism_patch_proposal_authorization",
    "oma_owned_receipt_or_typed_blocker"
  ],
  "notes": [
    "OMA may generate Stage Artifact Kernel ref templates for target agents.",
    "OMA does not create target runtime state, target owner receipts, target truth, target artifact bodies, target worktree lifecycle, Agent Lab runner state, or promotion verdicts."
  ]
}
