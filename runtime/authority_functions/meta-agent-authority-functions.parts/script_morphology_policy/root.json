{
  "policy_ref": "contracts/private_functional_surface_policy.json",
  "scripts_root": "scripts/",
  "script_scan_scope": {
    "mode": "repo_local_ts_and_shell_scripts",
    "included_extensions": [
      ".ts",
      ".sh"
    ],
    "gate_requirement": "every_scanned_script_ref_must_have_script_to_pack_retirement_or_retention_gate",
    "shell_wrappers_included": true,
    "no_exempt_shell_wrappers": true
  },
  "active_caller_scan_policy": {
    "policy_id": "oma.script-active-caller-scan.v1",
    "receipt_ref": "runtime/authority_functions/meta-agent-authority-functions.json#source_purity_scan_receipt.active_script_caller_scan",
    "active_caller_required": true,
    "orphan_script_count_must_be": 0,
    "scan_inputs": [
      "package.json#scripts",
      "scripts/**/*.ts import graph",
      "tests/**/*.ts import graph excluding tests/source-purity.test.ts self-guard strings",
      "scripts/**/*.sh shell invocations",
      "tests/**/*.ts direct script refs excluding tests/source-purity.test.ts"
    ],
    "self_guard_test_ref": "tests/source-purity.test.ts",
    "self_guard_may_prove_active_caller": false,
    "allowed_caller_ref_kinds": [
      "package_json_script",
      "typescript_import",
      "shell_invocation",
      "non_self_test_direct_ref"
    ],
    "proof_source_policy": {
      "policy_id": "oma.script-active-caller-proof-source.v1",
      "caller_proof_must_be_machine_scanned": true,
      "package_script_import_shell_or_non_self_test_ref_required": true,
      "self_guard_test_strings_count_as_caller": false,
      "test_ref_callers_must_be_outside_self_guard": true,
      "caller_ref_paths_must_exist": true,
      "receipt_must_not_synthesize_callers": true
    },
    "fail_closed_conditions": [
      "orphan_script_count_nonzero",
      "source_purity_self_guard_only_caller",
      "caller_ref_path_missing",
      "caller_proof_source_not_machine_scanned",
      "script_not_in_retirement_gate"
    ]
  },
  "allowed_classes": [
    "authority_function_implementation_ref",
    "smoke_helper",
    "fixture_or_proof_helper",
    "developer_work_order_materializer"
  ],
  "forbidden_roles": [
    "generic_runtime_owner",
    "generic_registry_owner",
    "app_shell_owner",
    "agent_lab_execution_owner",
    "promotion_gate_owner",
    "pack_compiler_owner",
    "generated_interface_owner",
    "scaffold_generator_owner",
    "target_pack_authority",
    "target_domain_truth_writer",
    "generic_cli_mcp_product_wrapper_owner",
    "generic_cli_mcp_skill_product_sidecar_status_workbench_materializer_owner",
    "generic_scheduler_or_daemon_owner",
    "generic_queue_or_attempt_ledger_owner"
  ],
  "allowed_opl_surface_consumption_policy_ref": "contracts/private_functional_surface_policy.json#allowed_opl_surface_consumption_refs"
}
