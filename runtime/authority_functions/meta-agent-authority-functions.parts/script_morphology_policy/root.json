{
  "policy_ref": "contracts/private_functional_surface_policy.json",
  "scripts_root": "scripts/",
  "script_scan_scope": {
    "mode": "repo_local_ts_and_shell_scripts",
    "included_extensions": [
      ".ts",
      ".sh"
    ],
    "gate_requirement": "every_scanned_script_ref_must_have_script_to_pack_retirement_or_retention_gate",
    "shell_wrappers_included": true,
    "no_exempt_shell_wrappers": true
  },
  "active_caller_scan_policy": {
    "policy_id": "oma.script-active-caller-scan.v1",
    "receipt_ref": "runtime/authority_functions/meta-agent-authority-functions.json#source_purity_scan_receipt.active_script_caller_scan",
    "active_caller_required": true,
    "orphan_script_count_must_be": 0,
    "scan_inputs": [
      "package.json#scripts",
      "scripts/**/*.ts import graph",
      "tests/**/*.ts import graph excluding source-purity self-guard refs",
      "scripts/**/*.sh shell invocations",
      "tests/**/*.ts direct script refs excluding source-purity self-guard refs"
    ],
    "self_guard_test_ref": "tests/source-purity.test.ts",
    "self_guard_may_prove_active_caller": false,
    "allowed_caller_ref_kinds": [
      "package_json_script",
      "typescript_import",
      "shell_invocation",
      "non_self_test_direct_ref"
    ],
    "proof_source_policy": {
      "policy_id": "oma.script-active-caller-proof-source.v1",
      "caller_proof_must_be_machine_scanned": true,
      "package_script_import_shell_or_non_self_test_ref_required": true,
      "self_guard_test_strings_count_as_caller": false,
      "test_ref_callers_must_be_outside_self_guard": true,
      "caller_ref_paths_must_exist": true,
      "receipt_must_not_synthesize_callers": true,
      "self_guard_module_strings_count_as_caller": false
    },
    "fail_closed_conditions": [
      "orphan_script_count_nonzero",
      "source_purity_self_guard_only_caller",
      "caller_ref_path_missing",
      "caller_proof_source_not_machine_scanned",
      "script_not_in_retirement_gate"
    ],
    "self_guard_test_refs": [
      "tests/source-purity.test.ts",
      "tests/source-purity/"
    ],
    "self_guard_module_scope": "tests/source-purity/"
  },
  "source_ref_integrity_guard": {
    "guard_id": "oma.script_morphology.source_ref_integrity_guard.v1",
    "state": "repo_local_script_refs_declared_no_second_truth",
    "readback_surface_ref": "contracts/script_to_pack_gate_receipt.json#current_scan_summary",
    "guarded_ref_collections": [
      "script_morphology_policy.script_classifications[*].script_ref",
      "script_morphology_policy.script_to_pack_retirement_gates[*].tracked_script_refs",
      "source_purity_scan_receipt.scanned_script_refs",
      "source_purity_scan_receipt.active_script_caller_scan.caller_refs_by_script[*].script_ref",
      "contracts/script_to_pack_gate_receipt.json#current_scan_summary.scanned_script_refs",
      "contracts/script_to_pack_gate_receipt.json#current_scan_summary.gated_script_refs"
    ],
    "required_ref_shape": "repo_local_relative_path_under_scripts",
    "allowed_ref_roots": [
      "scripts/"
    ],
    "allowed_extensions": [
      ".ts",
      ".sh"
    ],
    "forbidden_ref_shapes": [
      "absolute_path",
      "parent_directory_traversal",
      "uri_or_url",
      "empty_ref",
      "human_doc_ref_as_machine_source_ref",
      "non_scripts_root",
      "stale_or_missing_script_ref",
      "self_guard_only_caller_proof"
    ],
    "validation_policy": {
      "all_refs_must_be_repo_local": true,
      "all_refs_must_exist_in_repo_checkout": true,
      "all_refs_must_be_under_scripts_root": true,
      "script_classifications_must_match_scanned_script_refs": true,
      "retirement_gate_refs_must_match_scanned_script_refs": true,
      "current_scan_summary_must_match_source_purity_receipt": true,
      "human_doc_refs_do_not_count_as_machine_source_refs": true,
      "self_guard_strings_do_not_count_as_script_ref_integrity": true
    },
    "fail_closed_conditions": [
      "script_ref_missing_in_checkout",
      "script_ref_outside_scripts_root",
      "script_ref_uses_uri_or_absolute_path",
      "script_ref_uses_parent_directory_traversal",
      "script_ref_uses_human_doc_shape",
      "script_classification_ref_not_in_scan_scope",
      "retirement_gate_ref_not_in_scan_scope",
      "current_scan_summary_ref_drift",
      "source_purity_self_guard_only_caller"
    ],
    "authority_boundary": {
      "guard_can_create_missing_refs": false,
      "guard_can_create_alias_files": false,
      "guard_can_authorize_physical_delete": false,
      "guard_can_claim_opl_primitive_parity": false,
      "guard_can_claim_default_promotion_or_cutover": false,
      "guard_can_claim_app_or_registry_readiness": false,
      "guard_can_claim_generated_hosted_readiness": false,
      "guard_can_claim_target_agent_ready": false,
      "guard_can_claim_domain_ready": false,
      "guard_can_claim_production_ready": false
    }
  },
  "false_ready_claim_guard": {
    "guard_id": "oma.generated-hosted-false-ready-claim-guard.v1",
    "scope": "repo_machine_source",
    "forbidden_true_claim_keys": [
      "app_live_rendering_complete",
      "app_workbench_live_rendering_complete",
      "app_operator_sustained_consumption_complete",
      "registry_discovery_live_complete",
      "generated_interface_live_ready",
      "generated_hosted_surface_live_ready",
      "generated_surface_consumption_complete",
      "default_caller_cutover_complete",
      "default_promotion_complete",
      "retirement_readback_cleanup_complete",
      "retirement_readback_guard_satisfied",
      "cleanup_readback_physical_delete_authorized",
      "claims_cleanup_readback_authorizes_delete",
      "claims_retirement_cleanup_applied",
      "target_agent_ready",
      "domain_ready",
      "production_ready"
    ],
    "allowed_evidence_sources": [
      "OPL/App external evidence tail",
      "target owner receipt or typed blocker refs",
      "human gate receipt"
    ],
    "fail_closed_conditions": [
      "repo_machine_source_contains_forbidden_true_claim",
      "receipt_or_contract_claims_app_live_rendering_without_external_evidence",
      "receipt_or_contract_claims_registry_live_discovery_without_external_evidence",
      "receipt_or_contract_claims_generated_hosted_live_ready_without_external_evidence",
      "receipt_or_contract_claims_default_promotion_without_owner_gate"
    ],
    "authority_boundary": {
      "oma_can_claim_app_live_rendering": false,
      "oma_can_claim_registry_live_discovery": false,
      "oma_can_claim_generated_hosted_live_ready": false,
      "oma_can_claim_default_promotion": false,
      "oma_can_claim_target_agent_ready": false
    }
  },
  "retirement_readback_cleanup_guard": {
    "guard_id": "oma.script_morphology.retirement_readback_cleanup_guard.v1",
    "state": "readback_guard_available_physical_delete_not_authorized",
    "readback_surface_ref": "contracts/script_to_pack_gate_receipt.json#current_scan_summary",
    "allowed_readback_outputs": [
      "script_classification_readback",
      "missing_evidence_worklist",
      "owner_delta_route",
      "typed_blocker_ref_shape",
      "no_resurrection_policy"
    ],
    "forbidden_readback_outputs": [
      "physical_script_delete_operation",
      "owner_receipt_signature",
      "typed_blocker_instance_creation",
      "opl_primitive_parity_claim",
      "target_agent_ready_claim",
      "domain_ready_claim",
      "production_ready_claim",
      "app_registry_or_generated_hosted_readiness_claim",
      "default_promotion_or_default_caller_cutover_claim"
    ],
    "required_before_cleanup_apply": [
      "opl_primitive_parity_receipt_ref",
      "no_active_caller_ref",
      "no_forbidden_write_proof_ref_where_applicable",
      "tombstone_or_provenance_ref",
      "target_owner_or_OPL_owner_decision_ref_when_parity_is_claimed",
      "owner_receipt://opl-meta-agent/script_physical_delete_or_tombstone_authorization"
    ],
    "false_ready_claim_guard_keys": [
      "retirement_readback_cleanup_complete",
      "retirement_readback_guard_satisfied",
      "cleanup_readback_physical_delete_authorized",
      "claims_cleanup_readback_authorizes_delete",
      "claims_retirement_cleanup_applied"
    ],
    "claims": {
      "claims_retirement_cleanup_complete": false,
      "claims_physical_delete_authorized": false,
      "claims_owner_receipt_signed": false,
      "claims_typed_blocker_created": false,
      "claims_opl_primitive_parity": false,
      "claims_target_agent_ready": false,
      "claims_domain_ready": false,
      "claims_production_ready": false,
      "claims_app_registry_or_generated_hosted_ready": false,
      "claims_default_promotion_or_cutover": false
    },
    "authority_boundary": {
      "guard_can_identify_cleanup_candidates": true,
      "guard_can_route_owner_delta": true,
      "guard_can_authorize_physical_delete": false,
      "guard_can_sign_owner_receipt": false,
      "guard_can_create_typed_blocker": false,
      "guard_can_claim_opl_primitive_parity": false,
      "guard_can_claim_target_agent_ready": false,
      "guard_can_claim_domain_ready": false,
      "guard_can_claim_production_ready": false,
      "guard_can_claim_app_or_registry_readiness": false,
      "guard_can_claim_generated_hosted_readiness": false,
      "guard_can_claim_default_promotion_or_cutover": false
    }
  },
  "generic_materializer_no_resurrection_guard": {
    "guard_id": "oma.script_morphology.generic_materializer_no_resurrection_guard.v1",
    "state": "repo_machine_source_scan_declared_no_second_runtime_or_wrapper_materializer",
    "readback_surface_ref": "runtime/authority_functions/meta-agent-authority-functions.json#source_purity_scan_receipt.generic_script_materializer_scan",
    "scan_roots": [
      "scripts/",
      "runtime/authority_functions/",
      "contracts/",
      "agent/",
      "package.json"
    ],
    "forbidden_materializer_roles": [
      "repo_owned_cli_wrapper_materializer",
      "repo_owned_mcp_wrapper_materializer",
      "repo_owned_skill_wrapper_materializer",
      "repo_owned_product_entry_wrapper_materializer",
      "repo_owned_domain_action_adapter_wrapper_materializer",
      "repo_owned_status_read_model_materializer",
      "repo_owned_workbench_wrapper_materializer",
      "repo_owned_generic_runtime_materializer",
      "repo_owned_queue_or_attempt_ledger_materializer",
      "repo_owned_target_worktree_lifecycle_materializer"
    ],
    "retained_materializer_role": "refs_only_target_agent_semantics_work_order_candidate_or_typed_blocker_materializer",
    "allowed_outputs": [
      "candidate_agent_package_ref",
      "developer_patch_work_order_ref",
      "target_capability_improvement_candidate_ref",
      "mechanism_patch_proposal_ref",
      "typed_blocker_ref",
      "refs_only_contract_template_ref"
    ],
    "fail_closed_conditions": [
      "repo_machine_source_declares_repo_owned_generic_runtime_materializer",
      "repo_machine_source_declares_repo_owned_cli_mcp_skill_product_status_workbench_wrapper_materializer",
      "script_writes_runtime_state_or_queue_attempt_ledger",
      "script_manages_target_worktree_lifecycle_or_absorb_cleanup",
      "script_claims_generated_interface_or_pack_compiler_ownership"
    ],
    "authority_boundary": {
      "guard_can_claim_runtime_owner": false,
      "guard_can_claim_generated_interface_owner": false,
      "guard_can_claim_pack_compiler_owner": false,
      "guard_can_claim_agent_lab_runner_owner": false,
      "guard_can_manage_target_worktree_lifecycle": false,
      "guard_can_claim_target_agent_ready": false,
      "guard_can_claim_domain_ready": false,
      "guard_can_claim_production_ready": false
    }
  },
  "allowed_classes": [
    "authority_function_implementation_ref",
    "smoke_helper",
    "fixture_or_proof_helper",
    "developer_work_order_materializer"
  ],
  "forbidden_roles": [
    "generic_runtime_owner",
    "generic_registry_owner",
    "app_shell_owner",
    "agent_lab_execution_owner",
    "promotion_gate_owner",
    "pack_compiler_owner",
    "generated_interface_owner",
    "scaffold_generator_owner",
    "target_pack_authority",
    "target_domain_truth_writer",
    "generic_cli_mcp_product_wrapper_owner",
    "generic_cli_mcp_skill_product_sidecar_status_workbench_materializer_owner",
    "generic_scheduler_or_daemon_owner",
    "generic_queue_or_attempt_ledger_owner"
  ],
  "allowed_opl_surface_consumption_policy_ref": "contracts/private_functional_surface_policy.json#allowed_opl_surface_consumption_refs"
}
